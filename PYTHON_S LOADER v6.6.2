local function Fetch(url)
    local req = syn and syn.request or http_request
    if req then
        local resp = req({Url = url, Method = "GET", Headers = {}})
        if resp and resp.Success then return resp.Body end
    end
    return game:HttpGet(url)
end

local function LoadMode(url)
    LoadingLabel.Text = "Cargando..."
    LoadingLabel.TextColor3 = COLORS.Green
    task.spawn(function()
        local ok, err = pcall(function()
            local src = Fetch(url)
            if not src or src == "" then error("HTTP failed") end
            if writefile and loadfile then
                writefile("pythons_temp.lua", src)
                loadfile("pythons_temp.lua")()
            else
                loadstring(src)()
            end
        end)
        if ok then
            pcall(function() ScreenGui:Destroy() end)
        else
            LoadingLabel.Text = "Error: " .. tostring(err)
            LoadingLabel.TextColor3 = COLORS.Red
        end
    end)
end

local function createModeButton(parent, title, subtitle, features, posX, onClick)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.fromOffset(ButtonWidth, ButtonHeight)
    btn.Position = UDim2.new(0, posX, 0, StartY)
    btn.BackgroundColor3 = COLORS.CardBg
    btn.Text = ""
    btn.BorderSizePixel = 0
    btn.Parent = parent
    createCorner(btn, UDim.new(0, 10))
    createStroke(btn, COLORS.Border, 1)

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -16, 0, 22)
    titleLabel.Position = UDim2.new(0, 8, 0, 10)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = title
    titleLabel.TextColor3 = COLORS.Green
    titleLabel.TextSize = 15
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = btn

    local subLabel = Instance.new("TextLabel")
    subLabel.Size = UDim2.new(1, -16, 0, 14)
    subLabel.Position = UDim2.new(0, 8, 0, 32)
    subLabel.BackgroundTransparency = 1
    subLabel.Text = subtitle
    subLabel.TextColor3 = COLORS.TextSecondary
    subLabel.TextSize = 10
    subLabel.Font = Enum.Font.Gotham
    subLabel.TextXAlignment = Enum.TextXAlignment.Left
    subLabel.Parent = btn

    local divider = Instance.new("Frame")
    divider.Size = UDim2.new(1, -16, 0, 1)
    divider.Position = UDim2.new(0, 8, 0, 50)
    divider.BackgroundColor3 = COLORS.Border
    divider.BorderSizePixel = 0
    divider.Parent = btn

    local featureText = Instance.new("TextLabel")
    featureText.Size = UDim2.new(1, -16, 0, 70)
    featureText.Position = UDim2.new(0, 8, 0, 56)
    featureText.BackgroundTransparency = 1
    featureText.Text = features
    featureText.TextColor3 = COLORS.TextMuted
    featureText.TextSize = 9
    featureText.Font = Enum.Font.Code
    featureText.TextXAlignment = Enum.TextXAlignment.Left
    featureText.TextYAlignment = Enum.TextYAlignment.Top
    featureText.TextWrapped = true
    featureText.Parent = btn

    btn.MouseEnter:Connect(function()
        uiTween(btn, {BackgroundColor3 = COLORS.ControlBgHover}, 0.15)
        uiTween(titleLabel, {TextColor3 = COLORS.TextPrimary}, 0.15)
    end)
    btn.MouseLeave:Connect(function()
        uiTween(btn, {BackgroundColor3 = COLORS.CardBg}, 0.15)
        uiTween(titleLabel, {TextColor3 = COLORS.Green}, 0.15)
    end)
    btn.MouseButton1Click:Connect(onClick)

    return btn
end

