-- RENDER LOOP PRINCIPAL v6.4
--====================================================--
ConnectionManager.Add(RunService.RenderStepped:Connect(function()
    local loopStartTime = tick()
    local currentTime = loopStartTime

    if currentTime - CachedState.LastEnemyUpdate >= ScriptConfig.EnemyCacheUpdateRate then
        UpdateEnemyList()
        CachedState.LastEnemyUpdate = currentTime
    end

    if tick() - CachedState.LastRaycastReset > 0.016 then
        CachedState.RaycastCount = 0
        CachedState.LastRaycastReset = tick()
    end

    UpdateKeyState()
    UpdateAllChamsColors()
    StatisticsSystem.Update()

    local safeCamera = Utilities.GetSafeCamera()
    if not safeCamera then return end

    local Center
    if Aiming.FOVCenter == "Cursor" then
        Center = UserInputService:GetMouseLocation()
    else
        Center = Vector2.new(safeCamera.ViewportSize.X / 2, safeCamera.ViewportSize.Y / 2)
    end

    if Aiming.ShowFOV and Aiming.Enabled then
        FOVCircle.Radius = Aiming.FOV
        FOVCircle.Position = Center
        FOVCircle.Visible = true
    else
        FOVCircle.Visible = false
    end

    if Aiming.Enabled and IsKeyActive() and Utilities.ValidatePlayer(LocalPlayer) then
        local Target = AimbotSystem.FindTarget(Center)
        AimbotSystem.LockCamera(Target)
        if Target then
            CachedState.CurrentTarget = Target
            CachedState.TargetLockTime = tick()
        elseif not Aiming.AutoSwitch then
            CachedState.CurrentTarget = nil
        end
    else
        CachedState.CurrentTarget = nil
    end

    -- SelectionBox REMOVIDO (no se muestra)

    -- PartBox 3D Wireframe (Head CFrame)
    if ESPConfig.PartBox then
        for player, lines in pairs(PartBoxes) do
            if not Utilities.ValidatePlayer(player) then
                for _, line in ipairs(lines) do
                    line.Visible = false
                end
                continue
            end

            local cache = PartCacheSystem.Get(player)
            if not cache or not cache.Humanoid or cache.Humanoid.Health <= 0 then
                for _, line in ipairs(lines) do
                    line.Visible = false
                end
                continue
            end

            local isHeadMode = (Aiming.AimMode == "Cabeza")
            local anchor = isHeadMode and cache.Head or cache.HumanoidRootPart
            if not anchor then
                for _, line in ipairs(lines) do
                    line.Visible = false
                end
                continue
            end

            local cf = anchor.CFrame
            local w, h, d
            if isHeadMode then
                local hs = anchor.Size
                w = math.max(hs.X, hs.Z) * 1.15
                h = hs.Y * 1.15
                d = math.max(hs.X, hs.Z) * 1.15
            else
                local ut = cache.character:FindFirstChild("UpperTorso")
                local lt = cache.character:FindFirstChild("LowerTorso")
                local torsoH = 2.5
                local torsoW = 2.5
                local torsoD = 1.5
                if ut then
                    torsoW = ut.Size.X * 1.3
                    torsoD = ut.Size.Z * 1.3
                    torsoH = (ut.Size.Y + (lt and lt.Size.Y or 1.5)) * 1.2
                end
                w = torsoW
                h = torsoH
                d = torsoD
            end

            local hw, hh, hd = w / 2, h / 2, d / 2
            local corners = {
                cf * CFrame.new(-hw, hh, -hd),
                cf * CFrame.new(hw, hh, -hd),
                cf * CFrame.new(hw, hh, hd),
                cf * CFrame.new(-hw, hh, hd),
                cf * CFrame.new(-hw, -hh, -hd),
                cf * CFrame.new(hw, -hh, -hd),
                cf * CFrame.new(hw, -hh, hd),
                cf * CFrame.new(-hw, -hh, hd),
            }

            local screenPositions = {}
            for i = 1, 8 do
                local pos, onScreen = safeCamera:WorldToViewportPoint(corners[i].Position)
                screenPositions[i] = Vector2.new(pos.X, pos.Y)
            end

            local anchorPos, anchorOnScreen = safeCamera:WorldToViewportPoint(anchor.Position)
            -- FIX: Solo ocultar si esta detras de la camara
            if anchorPos.Z <= 0 then
                for _, line in ipairs(lines) do
                    line.Visible = false
                end
                continue
            end

            local edges = {
                {1, 2}, {2, 3}, {3, 4}, {4, 1},
                {5, 6}, {6, 7}, {7, 8}, {8, 5},
                {1, 5}, {2, 6}, {3, 7}, {4, 8},
            }

            local isWhitelisted = Aiming.WhitelistedPlayers[player.UserId]
            local isTarget = CachedState.CurrentTarget and CachedState.CurrentTarget.Parent == cache.character
            local isFriend = Aiming.FriendCheck and LocalPlayer:IsFriendsWith(player.UserId)

            local boxColor
            if isWhitelisted then
                boxColor = Aiming.WhitelistColor
            elseif isTarget then
                boxColor = Color3.new(1, 0, 0)
            elseif isFriend then
                boxColor = Color3.new(0, 1, 0)
            else
                boxColor = Color3.new(1, 1, 1)
            end

            for i, edge in ipairs(edges) do
                lines[i].From = screenPositions[edge[1]]
                lines[i].To = screenPositions[edge[2]]
                lines[i].Color = boxColor
                lines[i].Visible = true
            end
        end
    else
        for _, lines in pairs(PartBoxes) do
            for _, line in ipairs(lines) do
                line.Visible = false
            end
        end
    end

    LogPerformance()
    local frameTime = tick() - loopStartTime
    PerformanceStats.RenderTime = PerformanceStats.RenderTime + frameTime
    PerformanceStats.FrameCount = PerformanceStats.FrameCount + 1
    PerformanceStats.PeakFrameTime = math.max(PerformanceStats.PeakFrameTime, frameTime * 1000)
    PerformanceStats.MinFrameTime = math.min(PerformanceStats.MinFrameTime, frameTime * 1000)

    -- Item Drop ESP v6.5.1
    ItemDropESP.Update()

    -- Item Aura
    ItemAuraSystem.Update()

    -- Auto Drop Items
    AutoDropSystem.Update()
end))

