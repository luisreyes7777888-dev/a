local LastInputTime = 0

ConnectionManager.Add(UserInputService.InputBegan:Connect(function(input, proc)
    if proc or Aiming.ActivationMode ~= "Alternar" then return end

    local Key = Aiming.KeyString
    if not Key or Key == "" then return end

    Utilities.SafeCallback(function()
        local matched = false
        if string.find(Key, "MouseButton") then
            matched = input.UserInputType == Enum.UserInputType[Key]
        else
            matched = input.KeyCode == Enum.KeyCode[string.upper(Key)]
        end

        if matched then
            local currentTime = tick()
            if currentTime - LastInputTime >= ScriptConfig.InputDebounce then
                Aiming.ToggleState = not Aiming.ToggleState
                LastInputTime = currentTime
            end
        end
    end)
end))

