-- MEGA MEJORA #2: SISTEMA DE SUAVIZADO INTELIGENTE
--====================================================--
local SmoothingSystem = {}
SmoothingSystem.LastTargets = {}

function SmoothingSystem.SmoothAim(oldTarget, newTarget, smoothFactor)
    if not oldTarget or not newTarget then return newTarget end

    local smoothed = oldTarget:Lerp(newTarget, 1 - smoothFactor)
    return smoothed
end

function SmoothingSystem.GetSmoothedCamera(camera, targetPos, smoothFactor)
    if not camera or not targetPos then return camera.CFrame end

    local currentDir = camera.CFrame.LookVector
    local targetDir = (targetPos - camera.CFrame.Position).Unit

    local smoothedDir = currentDir:Lerp(targetDir, 1 - smoothFactor)
    return CFrame.lookAt(camera.CFrame.Position, camera.CFrame.Position + smoothedDir)
end

--====================================================--
-- MEGA MEJORA #3: SISTEMA DE FOV DINAMICO
--====================================================--
local DynamicFOVSystem = {}

function DynamicFOVSystem.CalculateFOV(targetDistance, baseDistance)
    baseDistance = baseDistance or 100

    if targetDistance <= 0 then return ScriptConfig.DynamicFOVMax end

    local ratio = math.min(targetDistance / baseDistance, 1)
    local dynamicFOV = ScriptConfig.DynamicFOVMin + (ScriptConfig.DynamicFOVMax - ScriptConfig.DynamicFOVMin) * ratio

    return math.clamp(dynamicFOV, ScriptConfig.DynamicFOVMin, ScriptConfig.DynamicFOVMax)
end

