--====================================================--
-- HELPER: GetClasses via StatefulObject upvalue
--====================================================--
local function GetClasses()
    local ok, result = pcall(function()
        local StatefulObject = require(game.ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Core"):WaitForChild("StatefulObject"))
        if debug.getupvalue then
            local classes = debug.getupvalue(StatefulObject.new_class, 3)
            if classes and type(classes) == "table" then return classes end
        end
        return nil
    end)
    if ok and result then return result end
    return nil
end

local function FindClassByName(Classes, targetName)
    if not Classes then return nil end
    for _, Class in next, Classes do
        if type(Class) ~= "table" then continue end
        if not Class.new or type(Class.new) ~= "function" then continue end
        local className = "???"
        pcall(function()
            if debug.getupvalue then
                local initiator = debug.getupvalue(Class.new, 3)
                if initiator and type(initiator) == "function" then
                    if getfenv then
                        local env = getfenv(initiator)
                        if env and env.script then
                            className = env.script.Name
                        end
                    end
                    if className == "???" and debug.info then
                        className = debug.info(initiator, "s") or "???"
                    end
                end
            end
        end)
        if className == targetName then
            return Class
        end
    end
    return nil
end

