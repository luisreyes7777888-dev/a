-- MEGA MEJORA #4: SISTEMA DE PRIORIZACION INTELIGENTE
--====================================================--
local PrioritizationSystem = {}
PrioritizationSystem.Weights = {
    Distance = 0.3,
    FOVCenter = 0.25,
    HealthPercentage = 0.2,
    TargetMovement = 0.15,
    WeaponThreat = 0.1
}

function PrioritizationSystem.CalculateScore(player, camera, center, aiming)
    local cache = CharacterPartCache[player] or {}
    local head = cache.Head

    if not head then return 0 end

    local distFromCenter = 999999
    if camera then
        local screenPos = camera:WorldToViewportPoint(head.Position)
        distFromCenter = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
    end

    local distScore = math.clamp(1 - (distFromCenter / 1000), 0, 1)
    local healthScore = cache.Humanoid and (cache.Humanoid.Health / cache.Humanoid.MaxHealth) or 0

    local totalScore = (distScore * PrioritizationSystem.Weights.Distance) +
                      (healthScore * PrioritizationSystem.Weights.HealthPercentage)

    return totalScore
end

