        end
    end

    table.sort(AssetIds)
    local Hash = 0
    local Concatenated = table.concat(AssetIds, ",")

    for i = 1, #Concatenated do
        Hash = (Hash * 31 + Concatenated:byte(i)) % 2 ^ 32
    end

    return Hash
end

local WeaponNameOverrides = {
    ["script"] = "Puños",
    ["bisteck"] = "Puños",
    ["725110"] = "Puños",
}

function WeaponSystem.ResolveName(tool, data)
    if not tool then return data end
    local name = tostring(data.Name or "")
    local nameLower = name:lower()

    if WeaponNameOverrides[nameLower] then
        return {Name = WeaponNameOverrides[nameLower], Rarity = data.Rarity or "Common"}
    end

    local isNumeric = name:match("^%d+$")

    if not isNumeric then return data end

    local attrName = tool:GetAttribute("ItemName")
        or tool:GetAttribute("Item")
        or tool:GetAttribute("WeaponName")
        or tool:GetAttribute("DisplayName")
        or tool:GetAttribute("Weapon")
        or tool:GetAttribute("Name")

    if attrName and not tostring(attrName):match("^%d+$") then
        return {Name = tostring(attrName), Rarity = data.Rarity or "Common"}
    end

    if #tool:GetChildren() > 0 then
        for _, child in ipairs(tool:GetChildren()) do
            if child:IsA("StringValue") and child.Value ~= "" and not child.Value:match("^%d+$") then
                return {Name = child.Value, Rarity = data.Rarity or "Common"}
            end
        end
    end

    return data
end

function WeaponSystem.GetToolData(tool)
    if not tool then return nil end

    if WeaponSystem.ToolInstanceCache[tool] then
        return WeaponSystem.ToolInstanceCache[tool]
    end

    local toolName = tool.Name

    local guidData = WeaponSystem.GuidToData[toolName]
    if guidData then
        local resolved = WeaponSystem.ResolveName(tool, guidData)
        WeaponSystem.ToolInstanceCache[tool] = resolved
        WeaponSystem.CacheSize = WeaponSystem.CacheSize + 1
        return resolved
    end

    local attrGuid = tool:GetAttribute("guid") or tool:GetAttribute("Guid") or tool:GetAttribute("GUID")
    if attrGuid then
        local attrData = WeaponSystem.GuidToData[tostring(attrGuid)]
        if attrData then
            local resolved = WeaponSystem.ResolveName(tool, attrData)
            WeaponSystem.ToolInstanceCache[tool] = resolved
            WeaponSystem.CacheSize = WeaponSystem.CacheSize + 1
            return resolved
        end
    end

    local hash = WeaponSystem.GenerateToolHash(tool)
    if hash and WeaponSystem.HashDatabase[hash] then
        local hashData = WeaponSystem.HashDatabase[hash]
        local resolved = WeaponSystem.ResolveName(tool, hashData)
        WeaponSystem.ToolInstanceCache[tool] = resolved
        WeaponSystem.CacheSize = WeaponSystem.CacheSize + 1
        return resolved
    end

    local fallbackData = {Name = toolName, Rarity = tool:GetAttribute("RarityName") or "Common"}
    local resolved = WeaponSystem.ResolveName(tool, fallbackData)

    if WeaponSystem.CacheSize >= ScriptConfig.MaxToolCacheSize then
        Utilities.SafeTableClear(WeaponSystem.ToolInstanceCache)
        WeaponSystem.CacheSize = 0
    end

    WeaponSystem.ToolInstanceCache[tool] = resolved
    WeaponSystem.CacheSize = WeaponSystem.CacheSize + 1

    return resolved
end

function WeaponSystem.InitializeDatabase()
    task.spawn(function()
        local ok, DataModule = Utilities.SafeCallWithRetry(function()
            local Modules = ReplicatedStorage:WaitForChild("Modules", 5)
            if not Modules then return nil end
            local Core = Modules:WaitForChild("Core", 3)
            if not Core then return nil end
            return require(Core:WaitForChild("Data", 3))
        end)

        if ok and DataModule and DataModule.items then
            for ItemType, ItemsByType in pairs(DataModule.items) do
                for ItemName, Items in pairs(ItemsByType) do
                    for _, ItemData in ipairs(Items) do
                        local name = ItemData.name or ItemName
                        local rarity = ItemData.rarity or (ItemData.class and ItemData.class.name) or "Common"
                        local guid = tostring(ItemData.guid or "")
                        if guid ~= "" then
                            WeaponSystem.GuidToData[guid] = {Name = name, Rarity = rarity}
                        end
                    end
                end
            end
            Utilities.Log("Core.Data cargado, guids: " .. (function() local c = 0 for _ in pairs(WeaponSystem.GuidToData) do c = c + 1 end return c end)(), "INFO")
        else
            Utilities.Log("Core.Data no encontrado, usando solo hash", "WARN")
        end

        local ok2, ItemsFolder = Utilities.SafeCallWithRetry(function()
            return ReplicatedStorage:WaitForChild("Items", 5)
        end)

        if ok2 and ItemsFolder then
            for _, Cat in ipairs(ItemsFolder:GetChildren()) do
                for _, Item in ipairs(Cat:GetChildren()) do
                    local hash = WeaponSystem.GenerateToolHash(Item)
                    if hash then
                        local name = Item.Name
                        local guidMatch = WeaponSystem.GuidToData[name]
                        if guidMatch then
                            WeaponSystem.HashDatabase[hash] = guidMatch
                        else
                            WeaponSystem.HashDatabase[hash] = {
                                Name = name,
                                Rarity = Item:GetAttribute("RarityName") or "Common"
                            }
                        end
                    end
                end
            end
            Utilities.Log("Base de datos de armas inicializada", "INFO")
        end
    end)
end

