    local PlayerManager = {}

    function PlayerManager.InitPlayer(player)
        if player == LocalPlayer then return end
        if PlayerESPActive[player] then return end

        PlayerESPActive[player] = true
        PartBoxes[player] = Graphics.CreatePartBoxLines()
        PredictionLines[player] = Graphics.CreatePredictionLine()

        -- CharacterAdded: cubre respawn real del servidor
        ConnectionManager.Add(player.CharacterAdded:Connect(function(char)
            task.spawn(function()
                task.wait(0.5)
                if char ~= player.Character then return end
                if char:FindFirstChild("ESP_Billboard") then return end
                PartCacheSystem.Cleanup(player)
                ESPSystem.CleanupBillboards(char)
                ESPSystem.CreatePlayerESP(char, player)
            end)
        end))

        -- GetPropertyChangedSignal: cubre re-entrada por STREAMING
        -- CharacterAdded NO dispara en el cliente cuando el personaje regresa al rango de replicacion
        ConnectionManager.Add(player:GetPropertyChangedSignal("Character"):Connect(function()
            local char = player.Character
            if not char then return end
            task.spawn(function()
                task.wait(0.5)
                if char ~= player.Character then return end
                if char:FindFirstChild("ESP_Billboard") then return end
                PartCacheSystem.Cleanup(player)
                ESPSystem.CleanupBillboards(char)
                ESPSystem.CreatePlayerESP(char, player)
            end)
        end))

        if player.Character then
            ESPSystem.CreatePlayerESP(player.Character, player)
        end
end

function PlayerManager.RemovePlayer(player)
    PlayerESPActive[player] = nil
    if PartBoxes[player] then
        for _, line in ipairs(PartBoxes[player]) do
            pcall(function() line:Remove() end)
        end
        PartBoxes[player] = nil
    end
    if PredictionLines[player] then
        pcall(function() PredictionLines[player]:Remove() end)
        PredictionLines[player] = nil
    end
    PartCacheSystem.Cleanup(player)
    PredictionSystem.Cleanup(player)
    CachedState.LastRaycastTime[player] = nil
    CachedState.PlayerDistanceCache[player] = nil
end

