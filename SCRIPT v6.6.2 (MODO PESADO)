--====================================================--
-- SISTEMA FLY JUMP (Infinite Jump)
--====================================================--
local FlyJumpSystem = {}
FlyJumpSystem.JumpDown = false
FlyJumpSystem.LastImpulse = 0
FlyJumpSystem.Connections = {}

function FlyJumpSystem.Setup()
    local inputBegan = UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if not MovementConfig.FlyJump then return end
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Enum.KeyCode.Space then
            FlyJumpSystem.JumpDown = true
        end
    end)
    local inputEnded = UserInputService.InputEnded:Connect(function(input, processed)
        if processed then return end
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == Enum.KeyCode.Space then
            FlyJumpSystem.JumpDown = false
        end
    end)
    table.insert(FlyJumpSystem.Connections, inputBegan)
    table.insert(FlyJumpSystem.Connections, inputEnded)

    local simConn = RunService.PreSimulation:Connect(function()
        if not MovementConfig.FlyJump then return end
        if not FlyJumpSystem.JumpDown then return end
        if tick() - FlyJumpSystem.LastImpulse < 0.1 then return end
        FlyJumpSystem.LastImpulse = tick()
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum then return end
        for _, part in next, char:GetDescendants() do
            if part:IsA("BasePart") then
                if hum.FloorMaterial == Enum.Material.Air then
                    if part.AssemblyLinearVelocity.Y < 50 then
                        part:ApplyImpulse(Vector3.yAxis * (7 / 1.2))
                    end
                end
            end
        end
    end)
    table.insert(FlyJumpSystem.Connections, simConn)
end

function FlyJumpSystem.Cleanup()
    MovementConfig.FlyJump = false
    for _, conn in pairs(FlyJumpSystem.Connections) do
        pcall(function() conn:Disconnect() end)
    end
    FlyJumpSystem.Connections = {}
end

