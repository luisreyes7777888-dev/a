-- Reemplazada con la version de WALL CHECK FIX v1.0
local function BuildRaycastBlacklist()
    local blacklist = {}
    if LocalPlayer.Character then
        for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                table.insert(blacklist, part)
            end
        end
        local localHum = LocalPlayer.Character:FindFirstChild("Humanoid")
        if localHum and localHum.SeatPart then
            table.insert(blacklist, localHum.SeatPart)
            if localHum.SeatPart.Parent then
                table.insert(blacklist, localHum.SeatPart.Parent)
            end
        end
    end
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = blacklist
    params.IgnoreWater = true
    return params
end

local CachedRayParams = nil
local CachedRayParamsTime = 0

local function IsVisibleThrottled(TargetPart, Character, player)
    if not Aiming.WallCheck then return true end
    if not TargetPart or not Character or not player then return true end

    local safeCamera = Utilities.GetSafeCamera()
    if not safeCamera or not LocalPlayer.Character then return true end

    if TargetPart:IsDescendantOf(LocalPlayer.Character) then
        return true
    end

    local lastVis = CachedState.LastVisibility[player]
    local origin = safeCamera.CFrame.Position
    local targetPos = TargetPart.Position
    local direction = targetPos - origin
    local distance = direction.Magnitude

    if distance <= 0 or distance > 5000 then
        CachedState.LastVisibility[player] = true
        return true
    end

    if not CachedRayParams or (tick() - CachedRayParamsTime) > 0.033 then
        CachedRayParams = BuildRaycastBlacklist()
        CachedRayParamsTime = tick()
    end

    local Result = workspace:Raycast(origin, direction, CachedRayParams)

    CachedState.RaycastCount = CachedState.RaycastCount + 1
    StatisticsSystem.Data.RaycastsPerformed = StatisticsSystem.Data.RaycastsPerformed + 1

    if not Result then
        CachedState.LastVisibility[player] = true
        return true
    end

    local hitInst = Result.Instance
    if hitInst and (hitInst:IsDescendantOf(Character) or hitInst == TargetPart) then
        CachedState.LastVisibility[player] = true
        return true
    end

    local hitPos = Result.Position
    local distToHit = (hitPos - targetPos).Magnitude
    if distToHit <= 2 then
        CachedState.LastVisibility[player] = true
        return true
    end

    local okCC, canCollide = pcall(function() return hitInst.CanCollide end)
    local okTR, transparency = pcall(function() return hitInst.Transparency end)
    canCollide = okCC and canCollide or true
    transparency = okTR and transparency or 0

    if (not canCollide) or (transparency and transparency > 0.7) then
        CachedState.LastVisibility[player] = true
        return true
    end

    CachedState.LastVisibility[player] = false
    return false
end

local function UpdateEnemyList()
