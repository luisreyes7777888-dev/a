function NoclipSystem.DisableCanCollideListeners(char)
    if not getconnections then return end
    for _, part in next, char:GetDescendants() do
        if part:IsA("BasePart") then
            local ok, conns = pcall(function()
                return getconnections(part:GetPropertyChangedSignal("CanCollide"))
            end)
            if ok and conns then
                for _, conn in next, conns do
                    pcall(function()
                        conn:Disable()
                        table.insert(NoclipSystem.DisabledConnections, conn)
                    end)
                end
            end
        end
    end
end

