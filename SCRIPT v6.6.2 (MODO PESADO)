local MeleeModsSystem = {}
MeleeModsSystem.Hooked = false
MeleeModsSystem._killAuraConn = nil
MeleeModsSystem._hookedGets = {}
MeleeModsSystem._heartbeatConn = nil

local MeleeModRefs = {
    cone_angle = "ConeAngle",
    range = "Range",
    damage = "Damage",
}

function MeleeModsSystem._doHook()
    local hookFn = hookfunction or replaceclosure
    if not hookFn then return end

    local Classes = GetClasses()
    if not Classes then return end

    local MeleeClass = FindClassByName(Classes, "Melee")
    if not MeleeClass then return end

    local Objects = MeleeClass.objects
    if not Objects then return end

    local hookedCount = 0
    for _, MeleeObj in next, Objects do
        if not MeleeObj then continue end
        local States = MeleeObj.states
        if not States then continue end
        for StateName, ConfigKey in pairs(MeleeModRefs) do
            local State = States[StateName]
            if State and type(State) == "table" and State.get and type(State.get) == "function" and not MeleeModsSystem._hookedGets[State.get] then
                local oldGet = State.get
                local ck = ConfigKey
                MeleeModsSystem._hookedGets[oldGet] = true
                pcall(function()
                    hookFn(oldGet, function(...)
                        if ck == "Range" and MeleeModsConfig.ExtendedRange then
                            return MeleeModsConfig.Range
                        elseif ck == "Speed" and MeleeModsConfig.Speed ~= 1.0 then
                            return MeleeModsConfig.Speed
                        elseif ck == "Damage" and MeleeModsConfig.Damage ~= 1.0 then
                            return MeleeModsConfig.Damage
                        elseif ck == "ConeAngle" and MeleeModsConfig.NoConeCheck then
                            return MeleeModsConfig.ConeAngle
                        end
                        return oldGet(...)
                    end)
                end)
                hookedCount = hookedCount + 1
            end
        end
    end

    if hookedCount > 0 then
        warn("[PYTHON_S] Melee: hooked " .. hookedCount .. " state getters")
    end
end

function MeleeModsSystem.Setup()
    if not FeatureCompat.MeleeExtended then return end
    if MeleeModsSystem._heartbeatConn then
        MeleeModsSystem._heartbeatConn:Disconnect()
        MeleeModsSystem._heartbeatConn = nil
    end
    local anyEnabled = MeleeModsConfig.ExtendedRange or MeleeModsConfig.NoConeCheck or MeleeModsConfig.Speed ~= 1.0 or MeleeModsConfig.Damage ~= 1.0
    if not anyEnabled then
        MeleeModsSystem.Hooked = false
        return
    end
    MeleeModsSystem._doHook()
    MeleeModsSystem._heartbeatConn = RunService.Heartbeat:Connect(function()
        local anyOn = MeleeModsConfig.ExtendedRange or MeleeModsConfig.NoConeCheck or MeleeModsConfig.Speed ~= 1.0 or MeleeModsConfig.Damage ~= 1.0
        if not anyOn then return end
        MeleeModsSystem._doHook()
    end)
    MeleeModsSystem.Hooked = true
end

function MeleeModsSystem.ToggleKillAura(enabled)
    MeleeModsConfig.KillAura = enabled
    if MeleeModsSystem._killAuraConn then
        MeleeModsSystem._killAuraConn:Disconnect()
        MeleeModsSystem._killAuraConn = nil
    end
    if enabled then
        MeleeModsSystem._killAuraConn = RunService.Heartbeat:Connect(function()
            if not MeleeModsConfig.KillAura then return end
            local char = LocalPlayer.Character
            if not char then return end
            local tool = char:FindFirstChildOfClass("Tool")
            if not tool then return end
            local isMelee = false
            for _, tag in pairs(game:GetService("CollectionService"):GetTags(tool)) do
                if tag:lower() == "melee" then isMelee = true; break end
            end
            if not isMelee then return end
            local pivot = char:GetPivot()
            local hitPlayers = {}
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer then
                    local pChar = player.Character
                    if pChar then
                        local pHRP = pChar:FindFirstChild("HumanoidRootPart")
                        local hum = pChar:FindFirstChildOfClass("Humanoid")
                        if pHRP and hum and not hum:GetAttribute("IsDead") then
                            local dist = (pChar:GetPivot().Position - pivot.Position).Magnitude
                            if dist <= 10 then
                                table.insert(hitPlayers, player)
                            end
                        end
                    end
                end
            end
            if #hitPlayers > 0 then
                pcall(function()
                    tool:Activate()
                    local remote = ReplicatedStorage:FindFirstChild("RemoteEvents")
                    if remote then
                        local meleeRemote = remote:FindFirstChild("melee_attack")
                        if meleeRemote then
                            local speedVal = 30 * 0.75 + math.random() * 30 * 0.25
                            meleeRemote:FireServer(tool, hitPlayers, pivot, speedVal)
                        end
                    end
                end)
                if MeleeModsConfig.Visualize then
                    pcall(function()
                        local vis = Instance.new("Part")
                        vis.Name = "OutdoorCeiling"
                        vis.Shape = Enum.PartType.Ball
                        vis.Size = Vector3.new(MeleeModsConfig.Range * 2, MeleeModsConfig.Range * 2, MeleeModsConfig.Range * 2)
                        vis.CanCollide = false
                        vis.CanQuery = false
                        vis.Anchored = true
                        vis.Material = Enum.Material.ForceField
                        vis.Color = #hitPlayers > 0 and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
                        vis.Transparency = 0.7
                        vis.CFrame = pivot
                        vis.Parent = workspace
                        game:GetService("Debris"):AddItem(vis, 0.5)
                    end)
                end
                task.wait(0.5)
            end
        end)
    end
end

function MeleeModsSystem.Cleanup()
    MeleeModsConfig.KillAura = false
    if MeleeModsSystem._killAuraConn then
        MeleeModsSystem._killAuraConn:Disconnect()
        MeleeModsSystem._killAuraConn = nil
    end
    if MeleeModsSystem._heartbeatConn then
        MeleeModsSystem._heartbeatConn:Disconnect()
        MeleeModsSystem._heartbeatConn = nil
    end
    MeleeModsSystem.Hooked = false
end

