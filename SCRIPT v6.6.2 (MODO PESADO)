    partCache.CachedName = nameLabel.Text
    partCache.LastNameUpdate = tick()
    nameLabel.Size = UDim2.new(1, 0, 0, 16)
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextColor3 = Color3.new(1, 1, 1)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextStrokeTransparency = 0.3
    nameLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    nameLabel.TextSize = 14
    nameLabel.TextScaled = false

    local healthFrame = Instance.new("Frame", mainFrame)
    healthFrame.Name = "HealthFrame"
    healthFrame.Size = UDim2.new(0.6, 0, 0, 2)
    healthFrame.BackgroundTransparency = 1

    local healthBack = Instance.new("Frame", healthFrame)
    healthBack.Name = "HealthBack"
    healthBack.Size = UDim2.new(1, 0, 1, 0)
    healthBack.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    healthBack.BorderSizePixel = 0

    local healthBar = Instance.new("Frame", healthBack)
    healthBar.Name = "HealthBar"
    healthBar.Size = UDim2.new(1, 0, 1, 0)
    healthBar.BackgroundColor3 = Color3.new(0, 1, 0)
    healthBar.BorderSizePixel = 0

    local healthPercentLabel = Instance.new("TextLabel", mainFrame)
    healthPercentLabel.Name = "StatusLine"
    healthPercentLabel.Size = UDim2.new(1, 0, 0, 14)
    healthPercentLabel.Font = Enum.Font.GothamBold
    healthPercentLabel.TextSize = 12
    healthPercentLabel.TextColor3 = Color3.new(1, 1, 1)
    healthPercentLabel.BackgroundTransparency = 1
    healthPercentLabel.TextStrokeTransparency = 0.3
    healthPercentLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    healthPercentLabel.TextScaled = false

    local toolsFrame = Instance.new("Frame", mainFrame)
    toolsFrame.Name = "ToolsFrame"
    toolsFrame.Size = UDim2.new(1, 0, 0, 0)
    toolsFrame.AutomaticSize = Enum.AutomaticSize.Y
    toolsFrame.BackgroundTransparency = 1

    local toolsLayout = Instance.new("UIListLayout", toolsFrame)
    toolsLayout.VerticalAlignment = Enum.VerticalAlignment.Top
    toolsLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    toolsLayout.Padding = UDim.new(0, 1)
    toolsLayout.FillDirection = Enum.FillDirection.Vertical

    local slots = {}
    for i = 1, 10 do
        local toolLabel = Instance.new("TextLabel", toolsFrame)
        toolLabel.Name = "ToolSlot" .. i
        toolLabel.Size = UDim2.new(1, 0, 0, 14)
        toolLabel.Font = Enum.Font.GothamBold
        toolLabel.TextSize = 13
        toolLabel.BackgroundTransparency = 1
        toolLabel.TextStrokeTransparency = 0.3
        toolLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
        toolLabel.TextScaled = false
        toolLabel.Visible = false
        slots[i] = toolLabel
    end

    local toolTracker = ToolTracker.Create(char, player)

    local healthConn
    healthConn = partCache.Humanoid.HealthChanged:Connect(function(newHealth)
        if not partCache.Humanoid or not partCache.Humanoid.Parent then
            if healthConn then healthConn:Disconnect() end
            return
        end
        local maxHp = partCache.Humanoid.MaxHealth
        if maxHp <= 0 then return end
        local hp = math.clamp(newHealth / maxHp, 0, 1)
        local hpColor = Color3.fromHSV(hp * 0.35, 1, 1)
        healthBar.Size = UDim2.new(hp, 0, 1, 0)
        healthBar.BackgroundColor3 = hpColor
    end)

    do
        local maxHp = partCache.Humanoid.MaxHealth
        if maxHp > 0 then
            local hp = math.clamp(partCache.Humanoid.Health / maxHp, 0, 1)
            local hpColor = Color3.fromHSV(hp * 0.35, 1, 1)
            healthBar.Size = UDim2.new(hp, 0, 1, 0)
            healthBar.BackgroundColor3 = hpColor
        end
    end

    local conn
    local lastUpdate = 0
    conn = ConnectionManager.Add(RunService.RenderStepped:Connect(function()
        local frameStartTime = tick()

        if not Utilities.ValidatePlayer(player) or not char or not char.Parent or not partCache.Humanoid or not partCache.Humanoid.Parent
            or not partCache.HumanoidRootPart or not partCache.HumanoidRootPart.Parent then
            pcall(function()
                predictionLine:Remove()
                billboard:Destroy()
                highlight:Destroy()
                for _, line in pairs(skeletonLines) do
                    pcall(function() line:Remove() end)
                end
                for _, line in pairs(cornerLines) do
                    pcall(function() line:Remove() end)
                end
                for _, line in pairs(box3DLines) do
                    pcall(function() line:Remove() end)
                end
            end)
            if healthConn then healthConn:Disconnect() end
            ToolTracker.Cleanup(toolTracker)
            -- GUARD: solo limpiar el cache global si aun pertenece a ESTE char.
            -- Evita destruir el cache de un ESP recien creado por streaming concurrente
            -- (GetPropertyChangedSignal puede haber creado un nuevo ESP antes de que
            -- este RenderStepped detecte el estado invalido del char anterior).
            local currentCache = CharacterPartCache[player]
            if currentCache and currentCache.character == char then
                PartCacheSystem.Cleanup(player)
            end
            PredictionSystem.Cleanup(player)
            -- Solo limpiar PredictionLines y PlayerESPActive si el jugador salio del servidor.
            -- Si sigue conectado, GetPropertyChangedSignal recreara el ESP al regresar.
            if not player.Parent then
                PredictionLines[player] = nil
                PlayerESPActive[player] = nil
            end
            if conn then conn:Disconnect() end
            return
        end

        if partCache.Humanoid.Health <= 0 then
            billboard.Enabled = false
            highlight.Enabled = false
            predictionLine.Visible = false
            for _, line in pairs(skeletonLines) do line.Visible = false end
            for _, line in pairs(cornerLines) do line.Visible = false end
            for _, line in pairs(box3DLines) do line.Visible = false end
            return
        end

        -- Throttling: skip si no ha pasado suficiente tiempo
        if tick() - lastUpdate < ESPConfig.UpdateInterval then return end
        lastUpdate = tick()

        local safeCamera = Utilities.GetSafeCamera()
        if not safeCamera then return end

        local pos, onScreen = safeCamera:WorldToViewportPoint(partCache.HumanoidRootPart.Position)
        local isWhitelisted = Aiming.WhitelistedPlayers[player.UserId]

        -- FIX: Solo ocultar si esta detras de la camara (Z <= 0)
        if pos.Z <= 0 then
            if billboard.Enabled then billboard.Enabled = false end
            if highlight.Enabled then highlight.Enabled = false end
            return
        end

        local dist = Utilities.SafeDistance(safeCamera.CFrame.Position, partCache.HumanoidRootPart.Position)
        CachedState.PlayerDistanceCache[player] = dist

        -- Distance check: 0 = sin limite
        if ESPConfig.MaxDistance > 0 and dist > ESPConfig.MaxDistance then
            if billboard.Enabled then billboard.Enabled = false end
            if highlight.Enabled then highlight.Enabled = false end
            return
        end

        PredictionSystem.RecordPosition(player, partCache.HumanoidRootPart.Position)

        billboard.Enabled = true
        highlight.Enabled = ESPConfig.Chams
        nameLabel.Visible = ESPConfig.Name
        healthFrame.Visible = ESPConfig.Health
        healthPercentLabel.Visible = ESPConfig.HealthPercent
        toolsFrame.Visible = ESPConfig.Tool

        highlight.FillColor = isWhitelisted and Aiming.WhitelistColor or ESPConfig.ChamsColor
        local finalColor = isWhitelisted and Aiming.WhitelistColor or Color3.new(1, 1, 1)

        if not isWhitelisted then
            local eq = ToolTracker.GetTool(toolTracker)
            if eq then
                local ok, d = pcall(function()
                    return WeaponSystem.GetToolData(eq)
                end)
                if ok and d then
                    finalColor = RarityColors[d.Rarity] or Color3.new(1, 1, 1)
                end
            end
        end

        local isTarget = (CachedState.CurrentTarget ~= nil)
            and (CachedState.CurrentTarget.Parent == char)
        local espColor = isTarget and Color3.new(1, 0, 0) or Color3.new(1, 1, 1)
        nameLabel.TextColor3 = espColor

        -- Skeleton ESP
        if ESPConfig.Skeleton then
            for _, bone in ipairs(skeletonBones) do
                local lineKey = bone[1] .. "_" .. bone[2]
                local line = skeletonLines[lineKey]
                local partA = char:FindFirstChild(bone[1])
                local partB = char:FindFirstChild(bone[2])
                if partA and partB then
                    local posA, onA = safeCamera:WorldToViewportPoint(partA.Position)
                    local posB, onB = safeCamera:WorldToViewportPoint(partB.Position)
                    if posA.Z > 0 and posB.Z > 0 then
                        line.From = Vector2.new(posA.X, posA.Y)
                        line.To = Vector2.new(posB.X, posB.Y)
                        line.Color = espColor
                        line.Visible = true
                    else
                        line.Visible = false
                    end
                else
                    line.Visible = false
                end
            end
        end

        -- Corner Box (CFrame-based 3D corners)
        if ESPConfig.CornerBox then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local cf = hrp.CFrame
                local w, h, d = 3, 5, 3
                local hw, hh, hd = w / 2, h / 2, d / 2

                local corners3D = {
                    cf * CFrame.new(-hw, hh, -hd),
                    cf * CFrame.new(hw, hh, -hd),
                    cf * CFrame.new(hw, hh, hd),
                    cf * CFrame.new(-hw, hh, hd),
                    cf * CFrame.new(-hw, -hh, -hd),
                    cf * CFrame.new(hw, -hh, -hd),
                    cf * CFrame.new(hw, -hh, hd),
                    cf * CFrame.new(-hw, -hh, hd),
                }

                local screenCorners = {}
                for i = 1, 8 do
                    local sp = safeCamera:WorldToViewportPoint(corners3D[i].Position)
                    screenCorners[i] = Vector2.new(sp.X, sp.Y)
                end

                if onScreen then
                    local edgeLen = math.max(10, math.min(
                        (screenCorners[2] - screenCorners[1]).Magnitude,
                        (screenCorners[1] - screenCorners[4]).Magnitude
                    ) * 0.25)

                    local corners2D = {
                        {screenCorners[1], Vector2.new(-1, 0), Vector2.new(0, -1)},
                        {screenCorners[2], Vector2.new(1, 0), Vector2.new(0, -1)},
                        {screenCorners[3], Vector2.new(1, 0), Vector2.new(0, 1)},
                        {screenCorners[4], Vector2.new(-1, 0), Vector2.new(0, 1)},
                        {screenCorners[5], Vector2.new(-1, 0), Vector2.new(0, -1)},
                        {screenCorners[6], Vector2.new(1, 0), Vector2.new(0, -1)},
                        {screenCorners[7], Vector2.new(1, 0), Vector2.new(0, 1)},
                        {screenCorners[8], Vector2.new(-1, 0), Vector2.new(0, 1)},
                    }
                    for i, c in ipairs(corners2D) do
                        cornerLines[i*2-1].From = c[1]
                        cornerLines[i*2-1].To = c[1] + c[2] * edgeLen
                        cornerLines[i*2-1].Color = espColor
                        cornerLines[i*2-1].Visible = true
                        cornerLines[i*2].From = c[1]
                        cornerLines[i*2].To = c[1] + c[3] * edgeLen
                        cornerLines[i*2].Color = espColor
                        cornerLines[i*2].Visible = true
                    end
                else
                    for _, line in pairs(cornerLines) do line.Visible = false end
                end
            end
        else
            for _, line in pairs(cornerLines) do line.Visible = false end
        end

        -- Box 3D (CFrame-based wireframe)
        if ESPConfig.Box then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local cf = hrp.CFrame
                local w, h, d = 3, 5, 3
                local hw, hh, hd = w / 2, h / 2, d / 2

                local boxCorners = {
                    cf * CFrame.new(-hw, hh, -hd),
                    cf * CFrame.new(hw, hh, -hd),
                    cf * CFrame.new(hw, hh, hd),
                    cf * CFrame.new(-hw, hh, hd),
                    cf * CFrame.new(-hw, -hh, -hd),
                    cf * CFrame.new(hw, -hh, -hd),
                    cf * CFrame.new(hw, -hh, hd),
                    cf * CFrame.new(-hw, -hh, hd),
                }

                local boxScreen = {}
                for i = 1, 8 do
                    local sp = safeCamera:WorldToViewportPoint(boxCorners[i].Position)
                    boxScreen[i] = Vector2.new(sp.X, sp.Y)
                end

                if onScreen then
                    local edges = {
                        {1, 2}, {2, 3}, {3, 4}, {4, 1},
                        {5, 6}, {6, 7}, {7, 8}, {8, 5},
                        {1, 5}, {2, 6}, {3, 7}, {4, 8},
                    }
                    for i, edge in ipairs(edges) do
                        box3DLines[i].From = boxScreen[edge[1]]
                        box3DLines[i].To = boxScreen[edge[2]]
                        box3DLines[i].Color = espColor
                        box3DLines[i].Visible = true
                    end
                else
                    for _, line in pairs(box3DLines) do line.Visible = false end
                end
            end
        else
            for _, line in pairs(box3DLines) do line.Visible = false end
        end

        if nameLabel.Visible and (tick() - partCache.LastNameUpdate) > ScriptConfig.NameUpdateRate then
            local newName = Utilities.SafeName(player)
            if newName ~= partCache.CachedName then
                nameLabel.Text = newName
                partCache.CachedName = newName
            end
            partCache.LastNameUpdate = tick()
        end

        local hpPct = math.floor((partCache.Humanoid.Health / math.max(partCache.Humanoid.MaxHealth, 1)) * 100)
        local statusText = "[" .. math.floor(dist) .. "M] [" .. hpPct .. "%]"
        healthPercentLabel.Text = statusText
        healthPercentLabel.TextColor3 = isTarget and Color3.new(1, 0, 0) or Color3.new(1, 1, 1)

        if ESPConfig.PredictionLine then
            local predictedPos = PredictionSystem.PredictPosition(player, ScriptConfig.PredictionFrames)
            if predictedPos then
                local predScreenPos = safeCamera:WorldToViewportPoint(predictedPos)
                if predScreenPos then
                    predictionLine.From = Vector2.new(pos.X, pos.Y)
                    predictionLine.To = Vector2.new(predScreenPos.X, predScreenPos.Y)
                    predictionLine.Visible = true
                    predictionLine.Color = Color3.fromRGB(0, 255, 100)
                end
            end
        else
            predictionLine.Visible = false
        end

        if ESPConfig.Tool then
            local items = {}
            local eq = ToolTracker.GetTool(toolTracker)
            if eq then
                local toolName = eq.Name:lower()
                if toolName ~= "first" and toolName ~= "fist" and toolName ~= "punch" and toolName ~= "puno" then
                    table.insert(items, {t = eq, e = true})
                end
            end

            local currentBackpack = player:FindFirstChild("Backpack")
            if currentBackpack then
                for _, t in ipairs(currentBackpack:GetChildren()) do
                    if t:IsA("Tool") then
                        local tName = t.Name:lower()
                        if tName ~= "first" and tName ~= "fist" and tName ~= "punch" and tName ~= "puno" then
                            table.insert(items, {t = t, e = false})
                        end
                    end
                end
            end

            -- Crear/destruir slots dinamicamente segun cantidad de tools
            while #slots < #items do
                local idx = #slots + 1
                local toolLabel = Instance.new("TextLabel", toolsFrame)
                toolLabel.Name = "ToolSlot" .. idx
                toolLabel.Size = UDim2.new(1, 0, 0, 13)
                toolLabel.Font = Enum.Font.GothamBold
                toolLabel.TextSize = 12
                toolLabel.BackgroundTransparency = 1
                toolLabel.TextStrokeTransparency = 0.3
                toolLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
                toolLabel.TextScaled = false
                toolLabel.Visible = false
                slots[idx] = toolLabel
            end

            for i = 1, math.max(#slots, #items) do
                local d = items[i]
                local slot = slots[i]
                if slot then
                    if d then
                        local ok, info = pcall(function()
                            return WeaponSystem.GetToolData(d.t) or { Name = tostring(d.t.Name), Rarity = "Common" }
                        end)
                        if not ok then info = { Name = tostring(d.t.Name), Rarity = "Common" } end

                        local displayName = tostring(info.Name)
                        local rarityColor = RarityColors[info.Rarity] or Color3.new(1, 1, 1)
                        slot.Text = "[" .. displayName .. "]"
                        slot.TextColor3 = rarityColor
                        slot.Visible = true
                    else
                        slot.Visible = false
                    end
                end
            end

            -- Redimensionar billboard segun cantidad de tools visibles
            local visibleCount = #items
            local baseHeight = 36
            if ESPConfig.Health then baseHeight = baseHeight + 3 end
            if ESPConfig.HealthPercent then baseHeight = baseHeight + 14 end
            local toolRowHeight = 14
            billboard.Size = UDim2.new(0, 180, 0, baseHeight + math.max(0, visibleCount - 2) * toolRowHeight)
        else
            toolsFrame.Visible = false
            for _, slot in ipairs(slots) do
                slot.Visible = false
            end
            local noToolBase = 36
            if ESPConfig.Health then noToolBase = noToolBase + 3 end
            if ESPConfig.HealthPercent then noToolBase = noToolBase + 14 end
            billboard.Size = UDim2.new(0, 180, 0, noToolBase)
        end

        PerformanceStats.RenderTime = PerformanceStats.RenderTime + (tick() - frameStartTime)
        PerformanceStats.FrameCount = PerformanceStats.FrameCount + 1
    end))
end

