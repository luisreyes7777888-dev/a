local ItemDropESP = {}
ItemDropESP.Drawings = {}   -- [item] = { label, tracer, box }
-- Carpetas comunes donde los juegos guardan items caidos en el mundo
ItemDropESP.FolderNames = {
    "Drops", "ItemDrops", "DroppedItems",
    "Loot", "WorldItems", "DroppedTools",
    "World", "GroundItems", "FloorItems"
}

local function ItemDrop_GetRoot(item)
    if item:IsA("Tool") then
        return item:FindFirstChild("Handle") or item:FindFirstChildWhichIsA("BasePart")
    elseif item:IsA("Model") then
        return item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
    end
    return nil
end

local function ItemDrop_IsDropped(item)
    -- Un item esta "caido" si no es descendiente de ningun jugador
    if not item.Parent then return false end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character and item:IsDescendantOf(p.Character) then return false end
        if item:IsDescendantOf(p.Backpack or p:FindFirstChildOfClass("Backpack") or Instance.new("Folder")) then return false end
    end
    return true
end

local function ItemDrop_Scan()
    local found = {}

    -- 1) Carpetas conocidas en workspace
    for _, folderName in ipairs(ItemDropESP.FolderNames) do
        local folder = workspace:FindFirstChild(folderName)
        if folder then
            for _, child in ipairs(folder:GetDescendants()) do
                if child.Parent and (
                    child:IsA("Tool")
                    or (child:IsA("Model") and (
                        child:GetAttribute("RarityName")
                        or child:GetAttribute("Rarity")
                        or child:GetAttribute("ItemName")
                        or child:FindFirstChildWhichIsA("BasePart")
                    ))
                ) then
                    if ItemDrop_IsDropped(child) then
                        found[child] = true
                    end
                end
            end
        end
    end

    -- 2) Tools directas en workspace (sin dueno de jugador)
    for _, child in ipairs(workspace:GetChildren()) do
        if child:IsA("Tool") and ItemDrop_IsDropped(child) then
            found[child] = true
        end
    end

    return found
end

function ItemDropESP.Update()
    -- Si esta desactivado, ocultar todo y salir
    if not ESPConfig.ItemDrop then
        for _, d in pairs(ItemDropESP.Drawings) do
            if d.label then d.label.Visible = false end
            if d.tracer then d.tracer.Visible = false end
        end
        return
    end

    local safeCamera = Utilities.GetSafeCamera()
    if not safeCamera then return end

    local localChar = LocalPlayer.Character
    local localRoot = localChar and localChar:FindFirstChild("HumanoidRootPart")

    local currentItems = ItemDrop_Scan()

    -- Limpiar drawings de items que ya desaparecieron
    local toRemove = {}
    for item in pairs(ItemDropESP.Drawings) do
        if not currentItems[item] or not item.Parent then
            local d = ItemDropESP.Drawings[item]
            if d.label then pcall(function() d.label:Remove() end) end
            if d.tracer then pcall(function() d.tracer:Remove() end) end
            if d.box then pcall(function() d.box:Destroy() end) end
            table.insert(toRemove, item)
        end
    end
    for _, item in ipairs(toRemove) do
        ItemDropESP.Drawings[item] = nil
    end

    -- Actualizar / crear drawings
    for item in pairs(currentItems) do
        if not item.Parent then continue end

        local root = ItemDrop_GetRoot(item)
        if not root then continue end

        local dist = localRoot
            and Utilities.SafeDistance(root.Position, localRoot.Position)
            or math.huge

        -- Ocultar si supera la distancia maxima
        if ESPConfig.ItemDropDistance > 0 and dist > ESPConfig.ItemDropDistance then
            local d = ItemDropESP.Drawings[item]
            if d then
                if d.label then d.label.Visible = false end
                if d.tracer then d.tracer.Visible = false end
                if d.box then d.box.Visible = false end
            end
            continue
        end

        local screenPos, onScreen = safeCamera:WorldToViewportPoint(root.Position)
        if not onScreen or screenPos.Z <= 0 then
            local d = ItemDropESP.Drawings[item]
            if d then
                if d.label then d.label.Visible = false end
                if d.tracer then d.tracer.Visible = false end
                if d.box then d.box.Visible = false end
            end
            continue
        end

        -- Crear los Drawing objects si aun no existen
        if not ItemDropESP.Drawings[item] then
            local label = Drawing.new("Text")
            label.Size     = 13
            label.Center   = true
            label.Outline  = true
            label.Font     = 3
            label.Visible  = false

            local tracer = Drawing.new("Line")
            tracer.Thickness = 1
            tracer.Visible   = false

            local box = Instance.new("BoxHandleAdornment")
            box.AlwaysOnTop = true
            box.ZIndex = 2
            box.Transparency = 0.6
            box.Visible = false

            ItemDropESP.Drawings[item] = { label = label, tracer = tracer, box = box }
        end

        local d = ItemDropESP.Drawings[item]

        -- ---- Obtener datos del item ----
        local itemName   = item.Name
        local rarity     = item:GetAttribute("RarityName")
                        or item:GetAttribute("Rarity")
                        or "Common"
        local rarityColor = RarityColors[rarity] or Color3.fromRGB(255, 255, 255)

        -- Enriquecer con WeaponSystem (usa el hash DB ya cargado)
        local ok, toolData = pcall(WeaponSystem.GetToolData, item)
        if ok and toolData and type(toolData) == "table" then
            local resolvedName = toolData.Name
            if resolvedName and resolvedName ~= "first" and resolvedName ~= "" then
                itemName = resolvedName
            end
            local resolvedRarity = toolData.Rarity
            if resolvedRarity and RarityColors[resolvedRarity] then
                rarity      = resolvedRarity
                rarityColor = RarityColors[rarity]
            end
        end

        if itemName:match("^%d+$") then
            local attrName = item:GetAttribute("ItemName") or item:GetAttribute("Item") or item:GetAttribute("WeaponName") or item:GetAttribute("Name")
            if attrName and not tostring(attrName):match("^%d+$") then
                itemName = tostring(attrName)
            end
        end

        -- Filtro de rareza
        local filterKey = "ItemDropFilter" .. rarity
        if ESPConfig[filterKey] == false then
            if ItemDropESP.Drawings[item] then
                local d = ItemDropESP.Drawings[item]
                if d.label then d.label.Visible = false end
                if d.tracer then d.tracer.Visible = false end
                if d.box then d.box.Visible = false end
            end
            continue
        end

        -- ---- Construir texto del label ----
        local parts = {}
        if ESPConfig.ItemDropName then
            table.insert(parts, itemName)
        end
        if ESPConfig.ItemDropRarity and rarity ~= "Common" then
            table.insert(parts, "[" .. rarity .. "]")
        end
        if ESPConfig.ItemDropDistance_Show then
            table.insert(parts, math.floor(dist) .. "m")
        end

        local labelText = #parts > 0 and table.concat(parts, " | ") or itemName

        -- ---- Aplicar al label ----
        local label = d.label
        label.Text     = labelText
        label.Color    = rarityColor
        label.Size     = math.clamp(14 / math.max(dist, 1) * 100, 10, 18)
        label.Position = Vector2.new(screenPos.X, screenPos.Y - 16)
        label.Visible  = true

        -- ---- Tracer opcional ----
        local tracer = d.tracer
        if ESPConfig.ItemDropTracers then
            tracer.From    = Vector2.new(safeCamera.ViewportSize.X / 2, safeCamera.ViewportSize.Y)
            tracer.To      = Vector2.new(screenPos.X, screenPos.Y)
            tracer.Color   = rarityColor
            tracer.Visible = true
        else
            tracer.Visible = false
        end

        -- ---- Box Handle opcional ----
        local box = d.box
        if ESPConfig.ItemDropBox then
            box.Size = root.Size + Vector3.new(0.5, 0.5, 0.5)
            box.Color3 = rarityColor
            box.Adornee = root
            box.Parent = root
            box.Visible = true
        else
            box.Visible = false
            box.Parent = nil
        end
    end
end

function ItemDropESP.Cleanup()
    for _, d in pairs(ItemDropESP.Drawings) do
        if d.label then pcall(function() d.label:Remove() end) end
        if d.tracer then pcall(function() d.tracer:Remove() end) end
        if d.box then pcall(function() d.box:Destroy() end) end
    end
    Utilities.SafeTableClear(ItemDropESP.Drawings)
end

