    ["M16"] = {x = 1.0, y = 0.9},
    ["AK47"] = {x = 1.2, y = 1.0},
    ["Default"] = {x = 0.5, y = 0.5}
}

function RecoilAnalysisSystem.GetRecoilPattern(weaponName)
    return RecoilAnalysisSystem.WeaponRecoil[weaponName] or RecoilAnalysisSystem.WeaponRecoil["Default"]
end

function RecoilAnalysisSystem.CompensateRecoil(aimPoint, recoilPattern, shotCount)
    if not aimPoint or not recoilPattern then return aimPoint end

    local compensation = Vector3.new(
        recoilPattern.x * shotCount * 0.1,
        recoilPattern.y * shotCount * 0.1,
        0
    )

    return aimPoint - compensation
end

