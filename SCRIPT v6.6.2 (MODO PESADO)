    local cache = CharacterPartCache[player]
    if cache then
        for _, conn in ipairs(cache.connections) do
            pcall(function() conn:Disconnect() end)
        end
        Utilities.SafeTableClear(cache.connections)
        CharacterPartCache[player] = nil
