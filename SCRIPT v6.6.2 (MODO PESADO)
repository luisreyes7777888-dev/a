function PartCacheSystem.Create(char, player)
    local cache = {
        player = player,
        character = char,
        Head = nil,
        HumanoidRootPart = nil,
        Humanoid = nil,
        Backpack = nil,
        LastNameUpdate = 0,
        CachedName = nil,
        LastPosition = nil,
        Velocity = Vector3.new(0, 0, 0),
        connections = {}
    }

    local function Update()
        cache.Head = char:FindFirstChild("Head")
        cache.HumanoidRootPart = char:FindFirstChild("HumanoidRootPart")
        cache.Humanoid = char:FindFirstChild("Humanoid")
        cache.Backpack = player:FindFirstChild("Backpack")

        if cache.HumanoidRootPart then
            if cache.LastPosition then
                cache.Velocity = cache.HumanoidRootPart.Position - cache.LastPosition
            end
            cache.LastPosition = cache.HumanoidRootPart.Position
        end
    end

    local descendantAddedConn = char.DescendantAdded:Connect(Update)
    table.insert(cache.connections, descendantAddedConn)

    Update()
    CharacterPartCache[player] = cache
    return cache
end

