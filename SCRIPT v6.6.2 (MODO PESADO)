--====================================================--
local ItemAuraSystem = {}
ItemAuraSystem.Connections = {}
ItemAuraSystem.LastScan = 0
ItemAuraSystem.ScanInterval = 0.1

function ItemAuraSystem.GetRarityFromName(ItemName)
    local ItemsFolder = ReplicatedStorage:FindFirstChild("Items")
    if not ItemsFolder then return "Common" end

    for _, Category in next, ItemsFolder:GetChildren() do
        for _, ItemInstance in next, Category:GetChildren() do
            if ItemInstance.Name == ItemName then
                return ItemInstance:GetAttribute("RarityName") or "Common"
            end
        end
    end
    return "Common"
end

function ItemAuraSystem.Update()
    if not ItemAuraConfig.Enabled then return end

    local currentTime = tick()
    if currentTime - ItemAuraSystem.LastScan < ItemAuraSystem.ScanInterval then return end
    ItemAuraSystem.LastScan = currentTime

    local Character = LocalPlayer.Character
    if not Character then return end
    local HumanoidRootPart = Character:FindFirstChild("HumanoidRootPart")
    if not HumanoidRootPart then return end

    local DroppedItems = workspace:FindFirstChild("DroppedItems")
    if not DroppedItems then return end

    for _, Item in next, DroppedItems:GetChildren() do
        if not Item:IsA("Model") then continue end
        if not Item.Parent then continue end

        local ItemPosition = Item:GetPivot().Position
        local CharacterPosition = Character:GetPivot().Position
        local Distance = (ItemPosition - CharacterPosition).Magnitude

        if Distance > ItemAuraConfig.Distance then continue end

        if Item.Name == "Money" then
            task.spawn(function()
                pcall(function()
                    local Remote = ReplicatedStorage:WaitForChild("RemoteEvents", 2)
                        and ReplicatedStorage.RemoteEvents:WaitForChild("Pickup_Dropped_Item", 2)
                    if Remote then
                        Remote:FireServer(Item)
                    end
                end)
            end)
            continue
        end

        if ItemAuraConfig.FilterByRarity then
            local Rarity = ItemAuraSystem.GetRarityFromName(Item.Name)
            if not ItemAuraConfig.AllowedRarities[Rarity] then
                continue
            end
        end

        task.spawn(function()
            pcall(function()
                local Remote = ReplicatedStorage:WaitForChild("RemoteEvents", 2)
                    and ReplicatedStorage.RemoteEvents:WaitForChild("Pickup_Dropped_Item", 2)
                if Remote then
                    Remote:FireServer(Item)
                end
            end)
        end)

        if not ItemAuraSystem.Connections[Item] then
            local Connection
            Connection = RunService.Heartbeat:Connect(function()
                if (not Item) or not Item.Parent then
                    if Connection then
                        Connection:Disconnect()
                        Connection = nil
                    end
                    ItemAuraSystem.Connections[Item] = nil
                    return
                end

                local PickUpZone = Item:FindFirstChild("PickUpZone")
                if PickUpZone and HumanoidRootPart and HumanoidRootPart.Parent then
                    pcall(function()
                        firetouchinterest(PickUpZone, HumanoidRootPart, 1)
                        firetouchinterest(PickUpZone, HumanoidRootPart, 0)
                    end)
                end
            end)
            ItemAuraSystem.Connections[Item] = Connection
        end
    end
end

function ItemAuraSystem.Cleanup()
    for Item, Connection in pairs(ItemAuraSystem.Connections) do
        pcall(function() Connection:Disconnect() end)
    end
    Utilities.SafeTableClear(ItemAuraSystem.Connections)
    ItemAuraSystem.LastScan = 0
end

--====================================================--
-- AUTO DROP ITEMS SYSTEM
--====================================================--
local AutoDropSystem = {}
AutoDropSystem.LastScan = 0
AutoDropSystem.ScanInterval = 0.5

function AutoDropSystem.DropTool(tool)
    if not tool or not tool.Parent then return end
    local success, err = pcall(function()
        local dropRemote = ReplicatedStorage:FindFirstChild("RemoteEvents") and
            ReplicatedStorage.RemoteEvents:FindFirstChild("DropItem")
        if dropRemote then
            dropRemote:FireServer(tool)
            return
        end
        local dropRemote2 = ReplicatedStorage:FindFirstChild("DropTool") or
            ReplicatedStorage:FindFirstChild("Events"):FindFirstChild("Drop")
        if dropRemote2 then
            dropRemote2:FireServer(tool)
            return
        end
        tool:Remove()
    end)
end

function AutoDropSystem.GetToolRarity(tool)
    local ok, data = pcall(WeaponSystem.GetToolData, tool)
    if ok and data and data.Rarity then
        return data.Rarity
    end
    local attrName = tool:GetAttribute("RarityName") or tool:GetAttribute("Rarity")
    if attrName then return attrName end
    return "Common"
end

function AutoDropSystem.Update()
    if not AutoDropConfig.Enabled then return end
    local currentTime = tick()
    if currentTime - AutoDropSystem.LastScan < AutoDropSystem.ScanInterval then return end
    AutoDropSystem.LastScan = currentTime
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return end
    local threshold = AutoDropConfig.ThresholdRarity
    local thresholdIndex = 0
    for i, r in ipairs({"Common","Uncommon","Rare","Epic","Legendary","Omega"}) do
        if r == threshold then thresholdIndex = i break end
    end
    if thresholdIndex <= 1 then return end
    for _, tool in ipairs(backpack:GetChildren()) do
        if not tool:IsA("Tool") then continue end
        local rarity = AutoDropSystem.GetToolRarity(tool)
        local rarityIndex = 0
        for i, r in ipairs({"Common","Uncommon","Rare","Epic","Legendary","Omega"}) do
            if r == rarity then rarityIndex = i break end
        end
        if rarityIndex < thresholdIndex then
            AutoDropSystem.DropTool(tool)
            task.wait(0.05)
        end
    end
end

function AutoDropSystem.Cleanup()
    AutoDropSystem.LastScan = 0
end

