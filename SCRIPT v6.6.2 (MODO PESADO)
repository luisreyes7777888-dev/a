local function EnsureToastGui()
    if AlertSystem.ToastGui and AlertSystem.ToastGui.Parent then return AlertSystem.ToastGui end
    local sg = Instance.new("ScreenGui")
    sg.Name = "PythonS_Toasts"
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.DisplayOrder = 1000
    sg.ResetOnSpawn = false
    sg.Parent = game:GetService("CoreGui")
    local layout = Instance.new("Frame", sg)
    layout.Name = "Container"
    layout.Size = UDim2.new(0, 300, 1, 0)
    layout.Position = UDim2.new(1, -310, 0, 10)
    layout.BackgroundTransparency = 1
    layout.BorderSizePixel = 0
    Instance.new("UIListLayout", layout).Padding = UDim.new(0, 6)
    Instance.new("UIListLayout", layout).VerticalAlignment = Enum.VerticalAlignment.Top
    AlertSystem.ToastGui = sg
    return sg
end

function AlertSystem.CreateAlert(title, content, duration, priority)
    priority = priority or 1
    duration = duration or 3

    table.insert(AlertSystem.Alerts, {
        title = title, content = content,
        duration = duration, priority = priority, time = tick()
    })

    pcall(function()
        local gui = EnsureToastGui()
        local container = gui.Container

        local toast = Instance.new("Frame")
        toast.Size = UDim2.new(1, 0, 0, 0)
        toast.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
        toast.BorderSizePixel = 0
        toast.AutomaticSize = Enum.AutomaticSize.Y
        toast.Parent = container
        Instance.new("UICorner", toast).CornerRadius = UDim.new(0, 8)
        local stroke = Instance.new("UIStroke", toast)
        stroke.Color = Color3.fromRGB(0, 220, 80)
        stroke.Thickness = 1
        stroke.Transparency = 0.5

        local lbl = Instance.new("TextLabel", toast)
        lbl.Size = UDim2.new(1, -16, 0, 0)
        lbl.Position = UDim2.new(0, 8, 0, 6)
        lbl.AutomaticSize = Enum.AutomaticSize.Y
        lbl.BackgroundTransparency = 1
        lbl.Text = "[" .. title .. "] " .. content
        lbl.TextColor3 = Color3.fromRGB(240, 240, 245)
        lbl.TextSize = 12
        lbl.Font = Enum.Font.GothamMedium
        lbl.TextXAlignment = Enum.TextXAlignment.Left
        lbl.TextWrapped = true
        lbl.TextStrokeTransparency = 0.5
        lbl.TextStrokeColor3 = Color3.new(0, 0, 0)

        toast.Size = UDim2.new(1, 0, 0, lbl.TextBounds.Y + 14)

        task.delay(duration, function()
            if toast and toast.Parent then toast:Destroy() end
        end)
    end)
end

function AlertSystem.GetHighPriorityAlert()
    table.sort(AlertSystem.Alerts, function(a, b)
        return a.priority > b.priority
    end)
    return AlertSystem.Alerts[1]
end

