local ToolTracker = {}

function ToolTracker.Create(char, player)
    local tracker = {
        character = char,
        player = player,
        currentTool = nil,
        connections = {}
    }

    local function UpdateTool(tool)
        tracker.currentTool = tool
    end

    local childAddedConn = char.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            UpdateTool(child)
        end
    end)
    table.insert(tracker.connections, childAddedConn)

    local childRemovedConn = char.ChildRemoved:Connect(function(child)
        if child:IsA("Tool") and tracker.currentTool == child then
            tracker.currentTool = nil
        end
    end)
    table.insert(tracker.connections, childRemovedConn)

    local initialTool = char:FindFirstChildOfClass("Tool")
    if initialTool then
        UpdateTool(initialTool)
    end

    return tracker
end

function ToolTracker.Cleanup(tracker)
    if tracker then
        for _, conn in ipairs(tracker.connections) do
            pcall(function() conn:Disconnect() end)
        end
        Utilities.SafeTableClear(tracker.connections)
    end
end

function ToolTracker.GetTool(tracker)
    if tracker and tracker.character and tracker.character.Parent then
        if tracker.currentTool and tracker.currentTool.Parent == tracker.character then
            return tracker.currentTool
        end
    end
    return nil
end

