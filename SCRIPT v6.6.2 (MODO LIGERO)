--====================================================--
-- BYPASS SYSTEM (Adapted from SGuard v4)
--====================================================--
shared.HOOKING_ENABLED = true

local PythonSBypass = {}
do
    local bypassSuccess, bypassErr = pcall(function()
        local Required = {
            "hookfunction", "getconnections", "setthreadcontext",
            "isexecutorclosure", "getrenv",
        }
        for _, v in next, Required do
            if not getgenv()[v] then
                warn("[PYTHON_S Bypass] Missing: " .. v .. " - hooking limited")
                shared.HOOKING_ENABLED = false
                return
            end
        end

        shared.HookRegistry = shared.HookRegistry or {}
        shared.Hooking = shared.Hooking or {}
        shared.Hooking.IncludeInStackFunctions = shared.Hooking.IncludeInStackFunctions or {}

        function PythonSBypass.SafeHook(Original, Replacement)
            shared.Hooking.IncludeInStackFunctions[Original] = true
            return hookfunction(Original, Replacement)
        end

        local function checkfirstcaller()
            local validlevel = debug.validlevel or debug.isvalidlevel or function(Level)
                return debug.info(Level + 1, "f") ~= nil
            end
            local Levels = { 4, 3 }
            for _, Level in ipairs(Levels) do
                if validlevel(Level) then
                    local Func = debug.info(Level, "f")
                    if Func and isexecutorclosure(Func) then
                        return true
                    end
                end
            end
            return false
        end

        local OldFenv = getrenv().getfenv
        if OldFenv then
            PythonSBypass.SafeHook(getrenv().getfenv, function(...)
                if checkfirstcaller() then
                    return OldFenv(...)
                end
                local ToInspect = ...
                if type(ToInspect) == "number" then
                    local RealEnv, ExecutorEnv = getrenv(), getgenv()
                    local Metatable = {
                        __index = function(_, Key)
                            if RealEnv[Key] ~= nil then
                                return RealEnv[Key]
                            elseif ExecutorEnv[Key] ~= nil and not RealEnv[Key] then
                                return nil
                            else
                                return OldFenv(ToInspect)[Key]
                            end
                        end,
                    }
                    return setmetatable({}, Metatable)
                end
                return OldFenv(...)
            end)
        end

        local BlacklistedSignals = {
            game:GetService("LogService").MessageOut,
            game:GetService("ScriptContext").Error,
        }
        for _, Signal in next, BlacklistedSignals do
            for _, Connection in next, getconnections(Signal) do
                if (Connection.Function and type(Connection.Function) == "function"
                    and isexecutorclosure(Connection.Function))
                    or Connection.Function == nil then
                    continue
                else
                    Connection:Disable()
                end
            end
        end

        local TargetScriptName = "ReplicatedFirst."
        local ThreadLinkedFunctions = {}
        local KilledThreads = 0
        for _, v in next, getreg() do
            if type(v) == "thread" then
                local src = debug.info(v, 1, "s")
                if src and src == TargetScriptName then
                    table.insert(ThreadLinkedFunctions, debug.info(v, 1, "f"))
                    coroutine.close(v)
                end
            end
        end
        for _, Object in next, getgc() do
            if type(Object) == "function" and (not isexecutorclosure(Object)) then
                if debug.info(Object, "s") == TargetScriptName then
                    local skip = false
                    for _, tf in next, ThreadLinkedFunctions do
                        if Object == tf then skip = true break end
                    end
                    if not skip then
                        KilledThreads += 1
                        hookfunction(Object, coroutine.yield)
                    end
                end
            end
        end
        print("[PYTHON_S] Bypass cargado. Eliminados", KilledThreads, "hilos anti-cheat.")
        print("[PYTHON_S] Bypass: OK")
    end)

    if not bypassSuccess then
        warn("[PYTHON_S] Bypass: ERROR -", bypassErr)
        shared.HOOKING_ENABLED = false
    end
end

