local function SelectTab(name)
    if CurrentTab == name then return end
    local tab = Tabs[name]
    if not tab then return end
    CurrentTab = name

    for _, frame in pairs(TabContents) do
        frame.Visible = false
    end
    tab.Content.Visible = true

    for _, t in pairs(Tabs) do
        uiTween(t.Icon, {TextColor3 = COLORS.TextMuted}, 0.2)
        uiTween(t.Text, {TextColor3 = COLORS.TextMuted}, 0.2)
        uiTween(t.Button, {BackgroundTransparency = 1}, 0.2)
    end

    uiTween(tab.Icon, {TextColor3 = COLORS.Green}, 0.2)
    uiTween(tab.Text, {TextColor3 = COLORS.TextPrimary}, 0.2)
    uiTween(tab.Button, {BackgroundTransparency = 0.85, BackgroundColor3 = COLORS.ControlBg}, 0.2)

    local btn = tab.Button
    local sidebarAbsY = Sidebar.AbsolutePosition.Y
    local btnAbsY = btn.AbsolutePosition.Y
    local offset = btnAbsY - sidebarAbsY

    ActiveIndicator.Position = UDim2.new(0, 0, 0, offset)
end

