function NoclipSystem.DisableCanCollideListeners(char)
    if not getconnections then return end
    for _, part in next, char:GetDescendants() do
        if part:IsA("BasePart") then
            local ok, conns = pcall(function()
                return getconnections(part:GetPropertyChangedSignal("CanCollide"))
            end)
            if ok and conns then
                for _, conn in next, conns do
                    pcall(function()
                        conn:Disable()
                        table.insert(NoclipSystem.DisabledConnections, conn)
                    end)
                end
            end
        end
    end
end

function NoclipSystem.Update()
    if not MovementConfig.Noclip then
        if NoclipSystem.Connection then
            NoclipSystem.Connection:Disconnect()
            NoclipSystem.Connection = nil
        end
        return
    end
    if NoclipSystem.Connection then return end
    NoclipSystem.Connection = RunService.Stepped:Connect(function()
        if not MovementConfig.Noclip then
            if NoclipSystem.Connection then
                NoclipSystem.Connection:Disconnect()
                NoclipSystem.Connection = nil
            end
            return
        end
        local char = LocalPlayer.Character
        if char then
            for _, part in next, char:GetDescendants() do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
    end)
end

function NoclipSystem.Cleanup()
    MovementConfig.Noclip = false
    if NoclipSystem.Connection then
        NoclipSystem.Connection:Disconnect()
        NoclipSystem.Connection = nil
    end
    NoclipSystem.DisabledConnections = {}
end

