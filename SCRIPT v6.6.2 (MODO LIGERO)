    chevron.Position = UDim2.new(1, -24, 0, 0)
    chevron.BackgroundTransparency = 1
    chevron.Text = Icons.ChevronDown
    chevron.TextColor3 = COLORS.TextMuted
    chevron.TextSize = 12
    chevron.Font = Enum.Font.Gotham
    chevron.ZIndex = 3
    chevron.Parent = dropdownBtn

    local optRef = {items = options}

    local selected = {}
    for _, v in ipairs(defaults or {}) do selected[v] = true end

    local function updateText()
        local parts = {}
        for _, opt in ipairs(optRef.items) do
            if selected[opt] then table.insert(parts, opt) end
        end
        if #parts == 0 then
            selectedLabel.Text = "Ninguno"
            selectedLabel.TextColor3 = COLORS.TextMuted
        elseif #parts <= 2 then
            selectedLabel.Text = table.concat(parts, ", ")
            selectedLabel.TextColor3 = COLORS.TextPrimary
        else
            selectedLabel.Text = parts[1] .. " +" .. (#parts - 1)
            selectedLabel.TextColor3 = COLORS.TextPrimary
        end
    end
    updateText()

    local isOpen = false
    local dropdownMenu = nil
    local function closeMenu()
        if dropdownMenu then
            for i, d in ipairs(OpenDropdowns) do
                if d == dropdownMenu then table.remove(OpenDropdowns, i) break end
            end
            uiTween(dropdownMenu, {Size = UDim2.new(0, 130, 0, 0)}, 0.15)
            task.wait(0.15)
            dropdownMenu:Destroy()
            dropdownMenu = nil
            isOpen = false
        end
    end
    local function openMenu()
        isOpen = true
        local currentOpts = optRef.items
        dropdownMenu = Instance.new("Frame")
        dropdownMenu.Size = UDim2.new(0, 130, 0, 0)
        local absPos = row.AbsolutePosition
        dropdownMenu.Position = UDim2.new(0, absPos.X + row.AbsoluteSize.X - 144, 0, absPos.Y + CONTROL_HEIGHT + 4)
        dropdownMenu.BackgroundColor3 = COLORS.BGTertiary
        dropdownMenu.BorderSizePixel = 0
        dropdownMenu.ZIndex = 50
        dropdownMenu.ClipsDescendants = true
        dropdownMenu.Parent = ScreenGui
        table.insert(OpenDropdowns, dropdownMenu)
        createCorner(dropdownMenu, UDim.new(0, 8))
        createStroke(dropdownMenu, COLORS.Border, 1)
        createList(dropdownMenu, Enum.FillDirection.Vertical, Enum.HorizontalAlignment.Left, Enum.VerticalAlignment.Top, 2)
        createPadding(dropdownMenu, 4, 4, 4, 4)
        for _, option in ipairs(currentOpts) do
            local optBtn = Instance.new("TextButton")
            optBtn.Size = UDim2.new(1, 0, 0, 28)
            optBtn.BackgroundColor3 = COLORS.ControlBg
            optBtn.BackgroundTransparency = 1
            optBtn.Text = ""
            optBtn.BorderSizePixel = 0
            optBtn.ZIndex = 51
            optBtn.Parent = dropdownMenu
            createCorner(optBtn, UDim.new(0, 5))
            local check = Instance.new("TextLabel")
            check.Size = UDim2.new(0, 20, 0, 28)
            check.Position = UDim2.new(0, 4, 0, 0)
            check.BackgroundTransparency = 1
            check.Text = selected[option] and "v" or ""
            check.TextColor3 = COLORS.Green
            check.TextSize = 13
            check.Font = Enum.Font.GothamBold
            check.ZIndex = 51
            check.Parent = optBtn
            local optLabel = Instance.new("TextLabel")
            optLabel.Size = UDim2.new(1, -28, 1, 0)
            optLabel.Position = UDim2.new(0, 24, 0, 0)
            optLabel.BackgroundTransparency = 1
            optLabel.Text = option
            optLabel.TextColor3 = selected[option] and COLORS.Green or COLORS.TextPrimary
            optLabel.TextSize = 11
            optLabel.Font = Enum.Font.GothamMedium
            optLabel.TextXAlignment = Enum.TextXAlignment.Left
            optLabel.ZIndex = 51
            optLabel.Parent = optBtn
            optBtn.MouseEnter:Connect(function()
                uiTween(optBtn, {BackgroundTransparency = 0.9}, 0.1)
                optBtn.BackgroundColor3 = COLORS.ControlBgHover
            end)
            optBtn.MouseLeave:Connect(function()
                uiTween(optBtn, {BackgroundTransparency = 1}, 0.1)
            end)
            optBtn.MouseButton1Click:Connect(function()
                selected[option] = not selected[option]
                check.Text = selected[option] and "v" or ""
                optLabel.TextColor3 = selected[option] and COLORS.Green or COLORS.TextPrimary
                updateText()
                if callback then callback(selected) end
            end)
        end
        uiTween(dropdownMenu, {Size = UDim2.new(0, 130, 0, #currentOpts * 30 + 8)}, 0.2)
    end
    dropdownBtn.MouseButton1Click:Connect(function()
        if isOpen then closeMenu() else openMenu() end
    end)
    local function refresh(newOptions)
        optRef.items = newOptions
        if isOpen and dropdownMenu then
            for i, d in ipairs(OpenDropdowns) do
                if d == dropdownMenu then table.remove(OpenDropdowns, i) break end
            end
            pcall(function() dropdownMenu:Destroy() end)
            dropdownMenu = nil
            isOpen = false
        end
        updateText()
    end
    return {Selected = selected, Update = updateText, Refresh = refresh}
end

