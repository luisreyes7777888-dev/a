local Utilities = {}

function Utilities.Log(message, level)
    level = level or "INFO"
    if ScriptConfig.Debug or level == "ERROR" then
        print(string.format("[PYTHON_S %s] %s", level, message))
    end
end

function Utilities.SafeTableClear(tbl)
    if type(tbl) == "table" then
        for k in pairs(tbl) do
            tbl[k] = nil
        end
    end
end

-- SafeCallWithRetry ahora devuelve (ok, result)
function Utilities.SafeCallWithRetry(func, maxAttempts)
    maxAttempts = maxAttempts or ScriptConfig.SafeCallMaxAttempts

    for attempt = 1, maxAttempts do
        local ok, result = pcall(func)
        if ok then
            return true, result
        end

        if attempt < maxAttempts then
            task.wait(0.05)
        end
    end

    Utilities.Log("SafeCall falló después de " .. maxAttempts .. " intentos", "ERROR")
    return false, nil
end

function Utilities.SafeCallback(callback, ...)
    if callback and type(callback) == "function" then
        local result = pcall(callback, ...)
        if MyConfig then pcall(function() MyConfig:Save() end) end
        return result
    end
    return false
end

function Utilities.ValidatePlayer(player)
    return player and player.Parent and player.Character
        and player.Character:FindFirstChild("Humanoid")
        and player.Character:FindFirstChild("HumanoidRootPart")
end

function Utilities.SafeGetCharacterPart(char, partName)
    if not char or not char.Parent then return nil end
    return char:FindFirstChild(partName)
end

function Utilities.GetScreenDistance(screenPos, center)
    if not screenPos or not center then return math.huge end
    return (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
end

function Utilities.ExtractValue(input)
    if type(input) == "table" then return input[1] end
    return input
end

-- Corregido ValidateColor3: Color3 es un value-type (typeof == "Color3")
function Utilities.ValidateColor3(color)
    return typeof(color) == "Color3"
end

function Utilities.CleanupInstance(instance)
    if instance and instance.Parent then
        pcall(function() instance:Destroy() end)
        return true
    end
    return false
end

function Utilities.GetSafeCamera()
    if Camera and Camera.Parent then
        return Camera
    end
    local newCam = workspace.CurrentCamera
    if newCam and newCam.Parent then
        Camera = newCam
        return Camera
    end
    return nil
end

function Utilities.SafeName(player)
    if not player then return "Unknown" end
    local name = player.DisplayName
    if name and name ~= "" then return tostring(name) end
    name = player.Name
    if name and name ~= "" then return tostring(name) end
    return "Unknown"
end

function Utilities.ValidateNumber(value, min, max, default)
    if not value or type(value) ~= "number" then return default end
    return math.clamp(value, min, max)
end

function Utilities.SafeDistance(pos1, pos2)
    if not pos1 or not pos2 then return math.huge end
    local distance = (pos1 - pos2).Magnitude
    return math.max(distance, 0)
end

function Utilities.IsTableEmpty(tbl)
    if type(tbl) ~= "table" then return true end
    return next(tbl) == nil
end

function Utilities.GetCameraVelocity(lastPos)
    if not Camera then return 0 end
    local currentPos = Camera.CFrame.Position
    local velocity = Utilities.SafeDistance(currentPos, lastPos or currentPos)
    return velocity
end

