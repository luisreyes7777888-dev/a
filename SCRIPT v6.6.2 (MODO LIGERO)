-- SISTEMA DE ITEM AURA (via firetouchinterest)
--====================================================--
local ItemAuraSystem = {}
ItemAuraSystem.Connections = {}
ItemAuraSystem.LastScan = 0
ItemAuraSystem.ScanInterval = 0.1

function ItemAuraSystem.GetRarityFromName(ItemName)
    local ItemsFolder = ReplicatedStorage:FindFirstChild("Items")
    if not ItemsFolder then return "Common" end

    for _, Category in next, ItemsFolder:GetChildren() do
        for _, ItemInstance in next, Category:GetChildren() do
            if ItemInstance.Name == ItemName then
                return ItemInstance:GetAttribute("RarityName") or "Common"
            end
        end
    end
    return "Common"
end

function ItemAuraSystem.Update()
    if not ItemAuraConfig.Enabled then return end

    local currentTime = tick()
    if currentTime - ItemAuraSystem.LastScan < ItemAuraSystem.ScanInterval then return end
    ItemAuraSystem.LastScan = currentTime

    local Character = LocalPlayer.Character
    if not Character then return end
    local HumanoidRootPart = Character:FindFirstChild("HumanoidRootPart")
    if not HumanoidRootPart then return end

    local DroppedItems = workspace:FindFirstChild("DroppedItems")
    if not DroppedItems then return end

    for _, Item in next, DroppedItems:GetChildren() do
        if not Item:IsA("Model") then continue end
        if not Item.Parent then continue end

        local ItemPosition = Item:GetPivot().Position
        local CharacterPosition = Character:GetPivot().Position
        local Distance = (ItemPosition - CharacterPosition).Magnitude

        if Distance > ItemAuraConfig.Distance then continue end

        if Item.Name == "Money" then
            task.spawn(function()
                pcall(function()
                    local Remote = ReplicatedStorage:WaitForChild("RemoteEvents", 2)
                        and ReplicatedStorage.RemoteEvents:WaitForChild("Pickup_Dropped_Item", 2)
                    if Remote then
                        Remote:FireServer(Item)
                    end
                end)
            end)
            continue
        end

        if ItemAuraConfig.FilterByRarity then
            local Rarity = ItemAuraSystem.GetRarityFromName(Item.Name)
            if not ItemAuraConfig.AllowedRarities[Rarity] then
                continue
            end
        end

        task.spawn(function()
            pcall(function()
                local Remote = ReplicatedStorage:WaitForChild("RemoteEvents", 2)
                    and ReplicatedStorage.RemoteEvents:WaitForChild("Pickup_Dropped_Item", 2)
                if Remote then
                    Remote:FireServer(Item)
                end
            end)
        end)

        if not ItemAuraSystem.Connections[Item] then
            local Connection
            Connection = RunService.Heartbeat:Connect(function()
                if (not Item) or not Item.Parent then
                    if Connection then
                        Connection:Disconnect()
                        Connection = nil
                    end
                    ItemAuraSystem.Connections[Item] = nil
                    return
                end

                local PickUpZone = Item:FindFirstChild("PickUpZone")
                if PickUpZone and HumanoidRootPart and HumanoidRootPart.Parent then
                    pcall(function()
                        firetouchinterest(PickUpZone, HumanoidRootPart, 1)
                        firetouchinterest(PickUpZone, HumanoidRootPart, 0)
                    end)
                end
            end)
            ItemAuraSystem.Connections[Item] = Connection
        end
    end
end

function ItemAuraSystem.Cleanup()
    for Item, Connection in pairs(ItemAuraSystem.Connections) do
        pcall(function() Connection:Disconnect() end)
    end
    Utilities.SafeTableClear(ItemAuraSystem.Connections)
    ItemAuraSystem.LastScan = 0
end

