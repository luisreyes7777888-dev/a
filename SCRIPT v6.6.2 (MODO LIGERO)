local WeaponSystem = {}
WeaponSystem.HashDatabase = {}
WeaponSystem.ToolInstanceCache = {}
WeaponSystem.CacheSize = 0

function WeaponSystem.GenerateToolHash(Tool)
    if not Tool then return nil end

    local AssetIds = {}
    for _, Descendant in ipairs(Tool:GetDescendants()) do
        if Descendant:IsA("MeshPart") then
            table.insert(AssetIds, (Descendant.MeshId or "") .. (Descendant.TextureID or "") .. Descendant.Material.Name)
        elseif Descendant:IsA("SpecialMesh") then
            local mat = Descendant.Parent:IsA("BasePart") and Descendant.Parent.Material.Name or ""
            table.insert(AssetIds, (Descendant.MeshId or "") .. (Descendant.TextureId or "") .. mat)
        end
    end

    table.sort(AssetIds)
    local Hash = 0
    local Concatenated = table.concat(AssetIds, ",")

    for i = 1, #Concatenated do
        Hash = (Hash * 31 + Concatenated:byte(i)) % 2 ^ 32
    end

    return Hash
end

function WeaponSystem.GetToolData(tool)
    if not tool then return nil end

    if WeaponSystem.ToolInstanceCache[tool] then
        return WeaponSystem.ToolInstanceCache[tool]
    end

    local hash = WeaponSystem.GenerateToolHash(tool)
    if not hash then return {Name = tool.Name, Rarity = "Common"} end

    local data = WeaponSystem.HashDatabase[hash] or {Name = tool.Name, Rarity = "Common"}
    local n = tostring(data.Name):lower()

    if n == "script" or n == "bisteck" or n == "725110" then
        data.Name = "first"
    elseif n == "127236" or n == "127235" or n == "remington" then
        data.Name = "Remington"
        data.Rarity = "Legendary"
    end

    if WeaponSystem.CacheSize >= ScriptConfig.MaxToolCacheSize then
        Utilities.SafeTableClear(WeaponSystem.ToolInstanceCache)
        WeaponSystem.CacheSize = 0
    end

    WeaponSystem.ToolInstanceCache[tool] = data
    WeaponSystem.CacheSize = WeaponSystem.CacheSize + 1

    return data
end

function WeaponSystem.InitializeDatabase()
    task.spawn(function()
        local ok, ItemsFolder = Utilities.SafeCallWithRetry(function()
            return ReplicatedStorage:WaitForChild("Items", 5)
        end)
        
        if not ok or not ItemsFolder then
            Utilities.Log("Items folder no encontrada", "WARN")
            return
        end

        for _, Cat in ipairs(ItemsFolder:GetChildren()) do
            for _, Item in ipairs(Cat:GetChildren()) do
                local hash = WeaponSystem.GenerateToolHash(Item)
                if hash then
                    WeaponSystem.HashDatabase[hash] = {
                        Name = Item.Name,
                        Rarity = Item:GetAttribute("RarityName") or "Common"
                    }
                end
            end
        end

        Utilities.Log("Base de datos de armas inicializada", "INFO")
    end)
end

