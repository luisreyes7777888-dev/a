createInfoRow(espResetCard, "+", "Reiniciar ESP", "Reconstruye el ESP sin reiniciar el script")
createButton(espResetCard, "Reiniciar ESP", function()
    Utilities.SafeCallback(function()

        -- 1. Desactivar actualizacion del ESP temporalmente
        local prevInterval = ESPConfig.UpdateInterval
        ESPConfig.UpdateInterval = math.huge

        -- 2. Recorrer todos los jugadores y eliminar el ESP existente
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end

            -- 2a. Eliminar BillboardGui y Highlight del character
            local char = player.Character
            if char then
                -- BillboardGui
                local billboard = char:FindFirstChild("ESP_Billboard")
                if billboard then pcall(function() billboard:Destroy() end) end

                -- Highlight
                local highlight = char:FindFirstChild("ESP_Highlight")
                if highlight then pcall(function() highlight:Destroy() end) end

                -- Cualquier objeto ESP residual
                for _, desc in ipairs(char:GetDescendants()) do
                    if desc:IsA("BillboardGui") then
                        pcall(function() desc:Destroy() end)
                    end
                    if desc:IsA("Highlight") then
                        pcall(function() desc:Destroy() end)
                    end
                    if desc:IsA("SelectionBox") then
                        pcall(function() desc:Destroy() end)
                    end
                end
            end

            -- 2b. Drawing API: PartBoxes (lineas wireframe 3D)
            if PartBoxes[player] then
                for _, line in ipairs(PartBoxes[player]) do
                    pcall(function() line:Remove() end)
                end
                PartBoxes[player] = nil
            end

            -- 2c. Drawing API: PredictionLines
            if PredictionLines[player] then
                pcall(function() PredictionLines[player]:Remove() end)
                PredictionLines[player] = nil
            end

        end

        -- 3. Limpiar tablas relacionadas con el ESP
        Utilities.SafeTableClear(PlayerESPActive)
        Utilities.SafeTableClear(CachedState.PlayerDistanceCache)
        Utilities.SafeTableClear(CachedState.LastVisibility)

        -- Limpiar CharacterPartCache y sus conexiones internas
        for player, _ in pairs(CharacterPartCache) do
            PartCacheSystem.Cleanup(player)
        end
        Utilities.SafeTableClear(CharacterPartCache)

        -- Limpiar historial de prediccion
        Utilities.SafeTableClear(PredictionSystem.TargetHistory)

        -- 4. Esperar a que Roblox sincronice personajes
        task.wait(0.5)

        -- 5. Recorrer jugadores y reconstruir el ESP para cada uno valido
        local rebuilt = 0
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end

            -- Verificar requisitos minimos
            if not Utilities.ValidatePlayer(player) then continue end

            local char = player.Character
            if not char then continue end

            local humanoid = char:FindFirstChild("Humanoid")
            if not humanoid then continue end

            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then continue end

            -- Evitar ESP duplicado
            if char:FindFirstChild("ESP_Billboard") then continue end
            if PlayerESPActive[player] then continue end

            -- Recrear Drawing objects para este jugador
            PlayerESPActive[player] = true
            PartBoxes[player] = Graphics.CreatePartBox()
            PredictionLines[player] = Graphics.CreatePredictionLine()

            -- Recrear el ESP usando la funcion existente
            task.spawn(function()
                ESPSystem.CleanupBillboards(char)
                ESPSystem.CreatePlayerESP(char, player)
            end)

            rebuilt = rebuilt + 1
        end

        -- 6. Restaurar el intervalo de actualizacion del ESP
        ESPConfig.UpdateInterval = prevInterval

        -- Notificacion de resultado
        AlertSystem.CreateAlert(
            "ESP Reiniciado",
            rebuilt .. " jugador(es) reconstruido(s) correctamente",
            4,
            1
        )

    end)
end)

