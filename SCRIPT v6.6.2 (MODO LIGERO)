local MovementDetectionSystem = {}
MovementDetectionSystem.LastPositions = {}

function MovementDetectionSystem.GetVelocity(player, currentPos)
    local lastPos = MovementDetectionSystem.LastPositions[player]
    MovementDetectionSystem.LastPositions[player] = currentPos

    if not lastPos then return Vector3.new(0, 0, 0) end

    return currentPos - lastPos
end

function MovementDetectionSystem.IsMovingFast(velocity, threshold)
    threshold = threshold or 1
    return velocity.Magnitude > threshold
end

