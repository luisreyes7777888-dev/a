local BoxEdges = {
    {1,2}, {3,4}, {5,6}, {7,8},
    {1,3}, {2,4}, {5,7}, {6,8},
    {1,5}, {2,6}, {3,7}, {4,8},
}

local function UpdatePartBox(lines, part, color)
    if not part or not part.Parent then
        for _, l in ipairs(lines) do l.Visible = false end
        return
    end
    local cf = part.CFrame
    local size = part.Size
    local half = size / 2
    local corners = {
        cf * CFrame.new(-half.X, -half.Y, -half.Z),
        cf * CFrame.new( half.X, -half.Y, -half.Z),
        cf * CFrame.new(-half.X,  half.Y, -half.Z),
        cf * CFrame.new( half.X,  half.Y, -half.Z),
        cf * CFrame.new(-half.X, -half.Y,  half.Z),
        cf * CFrame.new( half.X, -half.Y,  half.Z),
        cf * CFrame.new(-half.X,  half.Y,  half.Z),
        cf * CFrame.new( half.X,  half.Y,  half.Z),
    }
    local cam = workspace.CurrentCamera
    local screen = {}
    local allOnScreen = true
    for i, c in ipairs(corners) do
        local pos, vis = cam:WorldToViewportPoint(c.Position)
        screen[i] = Vector2.new(pos.X, pos.Y)
        if not vis then allOnScreen = false end
    end
    if not allOnScreen then
        for _, l in ipairs(lines) do l.Visible = false end
        return
    end
    for i, edge in ipairs(BoxEdges) do
        lines[i].From = screen[edge[1]]
        lines[i].To = screen[edge[2]]
        lines[i].Color = color
        lines[i].Visible = true
    end
end

local function HidePartBox(lines)
    for _, l in ipairs(lines) do l.Visible = false end
end

