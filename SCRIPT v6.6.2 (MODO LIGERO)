local function FullCleanup()
    local sgGui = game.CoreGui:FindFirstChild("ScriptHubUI")
    if sgGui then pcall(function() sgGui:Destroy() end) end
    ConnectionManager.CleanupAll()

    for _, lines in pairs(PartBoxes) do
        for _, l in ipairs(lines) do pcall(function() l:Remove() end) end
    end
    Utilities.SafeTableClear(PartBoxes)

    for _, line in pairs(PredictionLines) do
        pcall(function() line:Remove() end)
    end
    Utilities.SafeTableClear(PredictionLines)

    for player in pairs(CharacterPartCache) do
        PartCacheSystem.Cleanup(player)
        PredictionSystem.Cleanup(player)
    end
    Utilities.SafeTableClear(CharacterPartCache)

    Utilities.SafeTableClear(CachedState.LastRaycastTime)
    Utilities.SafeTableClear(CachedState.PlayerDistanceCache)
    Utilities.SafeTableClear(CachedState.ActiveEnemies)
    Utilities.SafeTableClear(PlayerESPActive)

    pcall(function() FOVCircle:Remove() end)

    -- Limpiar SelectionBox del target
    if CachedState.TargetSelectionBox then
        pcall(function() CachedState.TargetSelectionBox:Destroy() end)
        CachedState.TargetSelectionBox = nil
    end

    -- Limpiar Item Drop ESP v6.5.1
    ItemDropESP.Cleanup()

    -- Limpiar Item Aura
    ItemAuraSystem.Cleanup()

    -- Limpiar Movement Systems
    NoclipSystem.Cleanup()
    SpeedBoostSystem.Cleanup()
    FlyJumpSystem.Cleanup()

    -- Limpiar Automation Systems
    PromptSkipSystem.Cleanup()

    -- Limpiar Performance Systems
    LightingSystem.Cleanup()
    MeshDetailSystem.Cleanup()
    RemoveDetailsSystem.Cleanup()

    -- Limpiar Magic Bullet
    MagicBulletSystem.Cleanup()

    getgenv().PYTHON_S_V6_LOADED = false
    AlertSystem.CreateAlert("Script", "✅ Limpiado correctamente", 3, 1)
end

--====================================================--
-- RENDER LOOP PRINCIPAL v6.4
--====================================================--
ConnectionManager.Add(RunService.RenderStepped:Connect(function()
    local loopStartTime = tick()
    local currentTime = loopStartTime

    if currentTime - CachedState.LastEnemyUpdate >= ScriptConfig.EnemyCacheUpdateRate then
        UpdateEnemyList()
        CachedState.LastEnemyUpdate = currentTime
    end

    if tick() - CachedState.LastRaycastReset > 0.016 then
        CachedState.RaycastCount = 0
        CachedState.LastRaycastReset = tick()
    end

    UpdateKeyState()

    UpdateAllChamsColors()
    StatisticsSystem.Update()

    local safeCamera = Utilities.GetSafeCamera()
    if not safeCamera then return end

    local Center
    if Aiming.FOVCenter == "Cursor" then
        Center = UserInputService:GetMouseLocation()
    else
        Center = Vector2.new(safeCamera.ViewportSize.X / 2, safeCamera.ViewportSize.Y / 2)
    end

    if Aiming.ShowFOV and Aiming.Enabled then
        FOVCircle.Radius = Aiming.FOV
        FOVCircle.Position = Center
        FOVCircle.Visible = true
    else
        FOVCircle.Visible = false
    end

    if Aiming.Enabled and IsKeyActive() and Utilities.ValidatePlayer(LocalPlayer) then
        local Target = AimbotSystem.FindTarget(Center)
        AimbotSystem.LockCamera(Target)
        if Target then
            CachedState.CurrentTarget = Target
            CachedState.TargetLockTime = tick()
        else
            CachedState.CurrentTarget = nil
        end
    else
        CachedState.CurrentTarget = nil
    end

    -- SelectionBox REMOVIDO (no se muestra)

    for player, lines in pairs(PartBoxes) do
        local showBox = false

        if Aiming.HeadDotESP and Utilities.ValidatePlayer(player) then
            local cache = PartCacheSystem.Get(player)
            if cache then
                local isFriend = Aiming.FriendCheck and LocalPlayer:IsFriendsWith(player.UserId)
                local isTeam = Aiming.TeamCheck and player.Team == LocalPlayer.Team
                local isWhitelisted = Aiming.WhitelistedPlayers[player.UserId]

                if isWhitelisted or isFriend or (not isFriend and not isTeam) then
                    local part = nil
                    if Aiming.AimMode == "Cabeza" then
                        part = cache.Head
                    elseif Aiming.AimMode == "Cuerpo" then
                        part = cache.HumanoidRootPart
                    else
                        part = cache.Head or cache.HumanoidRootPart
                    end
                    if part and part.Parent then
                        local targetPlayer = CachedState.CurrentTarget and Players:GetPlayerFromCharacter(CachedState.CurrentTarget.Parent)
                        local color
                        if targetPlayer == player then
                            color = Color3.fromRGB(255, 0, 0)
                        elseif isWhitelisted then
                            color = Color3.fromRGB(0, 80, 255)
                        elseif isFriend then
                            color = Color3.fromRGB(0, 255, 0)
                        else
                            color = Color3.fromRGB(255, 255, 255)
                        end
                        UpdatePartBox(lines, part, color)
                        showBox = true
                    end
                end
            end
        end

        if not showBox then
            HidePartBox(lines)
        end
    end

    LogPerformance()
    local frameTime = tick() - loopStartTime
    PerformanceStats.RenderTime = PerformanceStats.RenderTime + frameTime
    PerformanceStats.FrameCount = PerformanceStats.FrameCount + 1
    PerformanceStats.PeakFrameTime = math.max(PerformanceStats.PeakFrameTime, frameTime * 1000)
    PerformanceStats.MinFrameTime = math.min(PerformanceStats.MinFrameTime, frameTime * 1000)

    -- Item Drop ESP v6.5.1
    ItemDropESP.Update()

    -- Item Aura
    ItemAuraSystem.Update()
end))

