    sliderTrack.Size = UDim2.new(1, -140, 0, 6)
    sliderTrack.Position = UDim2.new(0, 110, 0.5, -3)
    sliderTrack.BackgroundColor3 = COLORS.SliderTrack
    sliderTrack.BorderSizePixel = 0
    sliderTrack.Parent = row
